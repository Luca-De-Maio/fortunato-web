---
import { Image } from "astro:assets";
const { product } = Astro.props;
const formatPrice = (value) =>
  value ? `$ ${value.toLocaleString("es-AR")}` : "Precio a confirmar";
const priceLabel = formatPrice(product.price);
const compareAt = product.compareAt || null;
const discount = compareAt && product.price ? Math.round(100 - (product.price / compareAt) * 100) : null;
const hasCompare = Boolean(compareAt);
const compareLabel = formatPrice(compareAt || product.price || 0);
const discountLabel = discount ? `${discount}% OFF` : "00% OFF";
const attributeLine = product.microcopy?.trim()
  ? product.microcopy.trim()
  : product.materials?.length
  ? product.materials.slice(0, 2).join(" · ")
  : product.colors?.length
  ? product.colors.slice(0, 2).join(" · ")
  : "";
const defaultColor = product.colors?.[0] ?? "";
const defaultSize = product.sizes?.[0] ?? "";
const gridImage = product.gridImage || product.images?.[0] || "/placeholder.svg";
const cartImage = product.images?.[0] || gridImage || "/placeholder.svg";
const cardVariant = product.cardVariant === "double" ? "double" : "standard";
---
<article class:list={{ "product-card": true, "is-double": cardVariant === "double" }}>
  <a href={`/product/${product.slug}`} class="product-media">
    <Image
      src={gridImage}
      alt={product.name}
      loading="lazy"
      width={cardVariant === "double" ? 960 : 800}
      height={cardVariant === "double" ? 1200 : 1000}
      decoding="async"
    />
    {product.badge ? <span class="product-badge">{product.badge}</span> : null}
  </a>
  <div class="product-body">
    <a href={`/product/${product.slug}`} class="product-card-info" aria-label={`Ver ${product.name}`}>
      <h3>{product.name}</h3>
      {attributeLine ? <p class="product-attr">{attributeLine}</p> : null}
      <div class="price-stack">
        <p class="product-price">{priceLabel}</p>
        <p class:list={{ "product-compare": true, "is-placeholder": !hasCompare }} aria-hidden={hasCompare ? undefined : "true"}>
          <span class="compare-price">{compareLabel}</span>
          <span class="discount-pill">{discountLabel}</span>
        </p>
      </div>
    </a>
    <button
      class="btn btn-full"
      data-add-to-cart
      data-id={product.id}
      data-name={product.name}
      data-price={product.price ?? 0}
      data-currency={product.currency}
      data-image={cartImage}
      data-color={defaultColor}
      data-size={defaultSize}
    >
      Agregar al carrito
    </button>
  </div>
</article>
