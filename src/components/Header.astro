---
import { Image } from "astro:assets";
import logo from "../assets/logo.png";
const { current = "" } = Astro.props;
---
<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand">
      <span class="brand-logo-box">
        <Image
          src={logo}
          alt="Fortunato"
          class="brand-logo"
          width={320}
          height={202}
          priority
          decoding="async"
        />
      </span>
      <span class="brand-text">Fortunato</span>
    </a>
    <nav class="nav">
      <a href="/#capsula" class={current === "capsula" ? "is-active" : ""}>Cápsula</a>
      <a href="/#categorias" class={current === "categorias" ? "is-active" : ""}>Categorías</a>
      <a href="/#faq" class={current === "faq" ? "is-active" : ""}>FAQ</a>
      <a href="/cart" class="cart-link">
        Carrito
        <span class="cart-badge" data-cart-count></span>
      </a>
    </nav>
  </div>
</header>
