---
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
---

<Base title="Fortunato | Pago no confirmado" description="No pudimos acreditar el pago.">
  <Header />

  <main class="checkout-page">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Pago no confirmado</p>
        <h2>No pudimos acreditar el pago</h2>
        <p class="muted">La compra no llegó a confirmarse. Podés volver a intentarlo con Mercado Pago o escribirnos y te ayudamos a seguir.</p>
      </div>

      <div class="notice">
        <strong>Tu selección sigue disponible para reintentar.</strong> Estamos dejando todo listo para que puedas volver a pagar cuando quieras.
      </div>

      <div class="checkout-card" style="margin-top: 1rem;">
        <p class="eyebrow" style="margin-bottom: 0.35rem;">Cómo seguir</p>
        <ul class="checkout-note-list">
          <li>Volvé a tu selección y revisá el medio de pago.</li>
          <li>Podés intentar otra vez con Mercado Pago en unos segundos.</li>
          <li>Si preferís, te ayudamos por WhatsApp.</li>
        </ul>
      </div>

      <div class="checkout-actions">
        <a class="btn" href="/cart">Volver a mi selección</a>
        <a class="btn btn-ghost" href="https://wa.me/5491158204344">Hablar por WhatsApp</a>
      </div>

      <p class="muted" data-release-status style="margin-top: 1rem;">Estamos preparando tu selección para que puedas volver a intentarlo.</p>
    </div>
  </main>

  <Footer />

  <script>
    const status = document.querySelector("[data-release-status]");
    const params = new URLSearchParams(window.location.search);
    const reservationId = params.get("reservation_id") || params.get("external_reference");
    if (!reservationId) {
      if (status) status.textContent = "Podés volver a tu selección e intentarlo otra vez cuando quieras.";
    } else {
      fetch("/api/mercadopago/release", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ reservationId })
      })
        .then(() => {
          if (status) status.textContent = "Tu selección ya está lista para que vuelvas a intentar el pago.";
        })
        .catch(() => {
          if (status) status.textContent = "Podés volver a tu selección e intentarlo otra vez. Si necesitás ayuda, escribinos por WhatsApp.";
        });
    }
  </script>
</Base>
