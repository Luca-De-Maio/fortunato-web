---
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { getCombinationBySlug } from "../../lib/combinations";

export const prerender = false;

const { slug } = Astro.params;
const combo = await getCombinationBySlug(slug);
if (!combo) {
  throw new Response(null, { status: 404, statusText: "Not found" });
}

const formatPrice = (value: number, currency: string) =>
  `${currency} ${value.toLocaleString("es-AR")}`;

const mpAlias = (process.env.PUBLIC_MERCADOPAGO_ALIAS || "").trim();
---

<Base title={`Fortunato | ${combo.title}`} description={combo.notes || `Comprá ${combo.title} completo en Fortunato.`}>
  <Header />

  <main class="combo-page">
    <section class="section combo-section">
      <div class="container combo-layout">
        <div class="combo-media-card">
          <img src={combo.image || "/placeholder.svg"} alt={combo.title} width="1200" height="1500" decoding="async" />
        </div>

        <div class="combo-summary-card">
          <p class="eyebrow">Conjunto Fortunato</p>
          <h1>{combo.title}</h1>
          {combo.notes ? <p class="combo-lead">{combo.notes}</p> : null}

          <div class="combo-pricing">
            <p class="combo-price">{formatPrice(combo.bundlePrice, combo.currency)}</p>
            {combo.savingsAmount > 0 ? (
              <p class="combo-compare">
                <span>{formatPrice(combo.regularPrice, combo.currency)}</span>
                <span class="discount-pill">{combo.savingsPercent}% OFF</span>
              </p>
            ) : null}
            <p class="muted combo-installments">3 cuotas sin interés · 6 cuotas con interés</p>
          </div>

          <section class="combo-includes" aria-label="Qué incluye">
            <div class="combo-block-head">
              <h2>Qué incluye</h2>
              <p class="muted">Podés revisar cada prenda por separado antes de comprar el conjunto.</p>
            </div>

            <ul class="combo-item-list">
              {combo.items.map((item) => (
                <li class="combo-item-card">
                  <a href={`/product/${item.slug}`} class="combo-item-media" aria-label={`Ver ${item.name}`}>
                    <img src={item.image || "/placeholder.svg"} alt={item.name} width="240" height="300" loading="lazy" decoding="async" />
                  </a>
                  <div class="combo-item-copy">
                    <a href={`/product/${item.slug}`} class="combo-item-name">{item.name}</a>
                    {item.microcopy?.trim() ? (
                      <p class="muted">{item.microcopy}</p>
                    ) : item.materials?.length ? (
                      <p class="muted">{item.materials.slice(0, 2).join(" · ")}</p>
                    ) : null}
                    <p class="combo-item-price">{formatPrice(item.price, item.currency)}</p>
                  </div>
                </li>
              ))}
            </ul>
          </section>

          <div class="combo-cta-stack">
            <button
              class="btn"
              data-add-to-cart
              data-id={`combo-${combo.id}`}
              data-name={combo.title}
              data-price={combo.bundlePrice}
              data-currency={combo.currency}
              data-image={combo.image || "/placeholder.svg"}
            >
              Agregar conjunto al carrito
            </button>
            <button
              class="btn btn-ghost"
              type="button"
              data-buy-now
              data-id={`combo-${combo.id}`}
              data-name={combo.title}
              data-price={combo.bundlePrice}
              data-currency={combo.currency}
              data-image={combo.image || "/placeholder.svg"}
            >
              Comprar ahora
            </button>
          </div>

          {mpAlias ? (
            <div class="notice combo-alias">
              <div>
                <strong>Alias Mercado Pago:</strong>
                <p class="combo-alias-value">{mpAlias}</p>
              </div>
              <button type="button" class="btn btn-ghost combo-alias-copy" data-copy-alias>Copiar alias</button>
            </div>
          ) : null}
        </div>
      </div>
    </section>
  </main>

  <Footer />

  <script define:vars={{ mpAlias }}>
    const copyButton = document.querySelector("[data-copy-alias]");
    copyButton?.addEventListener("click", async () => {
      if (!mpAlias) return;
      try {
        await navigator.clipboard.writeText(mpAlias);
        const label = copyButton.textContent;
        copyButton.textContent = "Alias copiado";
        setTimeout(() => {
          copyButton.textContent = label || "Copiar alias";
        }, 1400);
      } catch {
        copyButton.textContent = "Copiá manualmente";
      }
    });
  </script>
</Base>

<style>
  .combo-page {
    padding-bottom: 4.5rem;
  }

  .combo-section {
    padding-top: 2.75rem;
  }

  .combo-layout {
    display: grid;
    gap: 2rem;
    grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.95fr);
    align-items: start;
  }

  .combo-media-card,
  .combo-summary-card {
    background: var(--white);
    border-radius: 24px;
    border: 1px solid rgba(24, 74, 69, 0.1);
    box-shadow: var(--shadow);
    overflow: hidden;
  }

  .combo-media-card img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
    image-orientation: from-image;
  }

  .combo-summary-card {
    padding: 2rem;
    display: grid;
    gap: 1.4rem;
  }

  .combo-summary-card h1 {
    font-family: "Cinzel", "Cormorant Garamond", serif;
    font-size: clamp(2rem, 3vw, 3rem);
    line-height: 1.04;
    color: var(--green);
  }

  .combo-lead {
    margin-top: -0.3rem;
    color: rgba(64, 67, 66, 0.88);
    font-size: 1rem;
  }

  .combo-pricing {
    display: grid;
    gap: 0.35rem;
    padding: 1rem 1.1rem;
    background: rgba(245, 232, 215, 0.38);
    border-radius: 18px;
    border: 1px solid rgba(24, 74, 69, 0.08);
  }

  .combo-price {
    font-size: 1.8rem;
    font-weight: 800;
    color: var(--green);
  }

  .combo-compare {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    align-items: center;
    color: rgba(64, 67, 66, 0.72);
  }

  .combo-compare span:first-child {
    text-decoration: line-through;
  }

  .combo-installments {
    margin-top: 0.2rem;
  }

  .combo-includes {
    display: grid;
    gap: 0.9rem;
  }

  .combo-block-head {
    display: grid;
    gap: 0.2rem;
  }

  .combo-block-head h2 {
    font-family: "Outfit", system-ui, sans-serif;
    font-size: 1.15rem;
    color: var(--ink);
  }

  .combo-item-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.85rem;
  }

  .combo-item-card {
    display: grid;
    grid-template-columns: 88px 1fr;
    gap: 0.85rem;
    align-items: center;
    padding: 0.8rem;
    border-radius: 18px;
    border: 1px solid rgba(24, 74, 69, 0.08);
    background: rgba(245, 232, 215, 0.24);
  }

  .combo-item-media img {
    width: 88px;
    height: 110px;
    object-fit: cover;
    border-radius: 14px;
    image-orientation: from-image;
  }

  .combo-item-copy {
    display: grid;
    gap: 0.22rem;
  }

  .combo-item-name {
    font-weight: 600;
    color: var(--ink);
  }

  .combo-item-price {
    margin-top: 0.2rem;
    font-weight: 700;
    color: var(--green);
  }

  .combo-cta-stack {
    display: grid;
    gap: 0.7rem;
  }

  .combo-alias {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
  }

  .combo-alias-value {
    margin-top: 0.35rem;
    font-weight: 700;
    color: var(--green);
    overflow-wrap: anywhere;
  }

  .combo-alias-copy {
    flex: 0 0 auto;
  }

  @media (max-width: 960px) {
    .combo-layout {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 760px) {
    .combo-section {
      padding-top: 1.35rem;
    }

    .combo-summary-card {
      padding: 1.2rem;
      gap: 1rem;
    }

    .combo-item-card {
      grid-template-columns: 72px 1fr;
      gap: 0.7rem;
    }

    .combo-item-media img {
      width: 72px;
      height: 92px;
    }

    .combo-alias {
      display: grid;
    }
  }
</style>
