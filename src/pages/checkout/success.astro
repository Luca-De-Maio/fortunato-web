---
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
---

<Base title="Fortunato | Pago aprobado" description="Tu pago fue aprobado.">
  <Header />

  <main class="checkout-page">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Mercado Pago</p>
        <h2>Pago aprobado</h2>
        <p class="muted">Gracias. Recibimos tu pago y estamos preparando tu pedido.</p>
      </div>

      <div class="notice">
        <strong>¿Querés confirmar por WhatsApp?</strong> Si necesitás coordinar envío o tenés dudas de talle, escribinos.
      </div>

      <div style="margin-top: 1.4rem; display: grid; gap: 0.8rem;">
        <a class="btn" href="/">Volver al inicio</a>
        <a class="btn btn-ghost" href="https://wa.me/5491158204344">Hablar por WhatsApp</a>
      </div>
    </div>
  </main>

  <Footer />

  <script>
    try { localStorage.setItem("fortunato_cart", "[]"); } catch {}
  </script>
</Base>
