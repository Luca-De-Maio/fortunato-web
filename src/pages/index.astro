---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ProductCard from "../components/ProductCard.astro";
import ComboCarousel from "../components/ComboCarousel.astro";
import EditorialShowcase from "../components/EditorialShowcase.astro";
import FAQ from "../components/FAQ.astro";
import { getAllProducts } from "../lib/products";
import { getAllCombinations } from "../lib/combinations";

const heroTitle = "Elegancia moderna para el hombre que honra su destino.";
const heroCopy = "Fortunato es la herencia del old money guiada por el pulso de lo eterno. Una cápsula limitada, sobria y auténtica, con materiales nobles y cortes precisos.";

export const prerender = false;

const products = await getAllProducts();
const homeOrder = [
  "camisa-riviera",
  "chomba-sprezzata",
  "remera-doppio-collo",
  "pantalon-sastrero",
  "bermuda-rilassata",
  "bermuda-sastrera",
  "sandalias-crudem"
];
const orderIndex = new Map(homeOrder.map((id, index) => [id, index]));
const orderedProducts = [...products].sort((a, b) => {
  const aIndex = orderIndex.has(a.id) ? orderIndex.get(a.id) : Number.MAX_SAFE_INTEGER;
  const bIndex = orderIndex.has(b.id) ? orderIndex.get(b.id) : Number.MAX_SAFE_INTEGER;
  if (aIndex !== bIndex) return aIndex - bIndex;
  return String(a.name || "").localeCompare(String(b.name || ""), "es");
});
const combinations = await getAllCombinations();
---

<Base title="Fortunato | Moda masculina premium" description="Cápsula limitada de prendas premium inspiradas en la herencia italo-argentina.">
  <Header />
  <main>
    <section id="capsula" class="section section-capsule">
      <div class="container">
        <div class="capsule-grid">
          {orderedProducts.map((product) => (
            <ProductCard product={product} />
          ))}
        </div>
      </div>
    </section>

    <section id="conjuntos" class="section">
      <div class="container">
        <div class="section-head">
          <p class="eyebrow">Conjuntos</p>
          <h2>Looks listos para comprar en un solo paso.</h2>
          <p class="muted">Entrá al conjunto, revisá qué incluye y cerrá el pedido desde el carrito.</p>
        </div>
        <ComboCarousel combinations={combinations} />
      </div>
    </section>

    <section class="hero">
      <div class="hero-video is-autoplay">
        <iframe
          src="https://www.youtube.com/embed/akSPGeVQixU?autoplay=1&playsinline=1&rel=0&loop=1&playlist=akSPGeVQixU&mute=1&controls=0&modestbranding=1&iv_load_policy=3"
          title="Video de presentación Fortunato"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen
        ></iframe>
      </div>
      <div class="container hero-grid">
        <div>
          <p class="eyebrow">Cápsula verano 2026</p>
          <h1>{heroTitle}</h1>
          <p>{heroCopy}</p>
          <div class="hero-actions">
            <a href="#capsula" class="btn">Ver cápsula</a>
            <a href="#editorial" class="btn btn-ghost">Ver editorial</a>
          </div>
        </div>
      </div>
    </section>

    <EditorialShowcase />

    <FAQ />
  </main>

  <Footer />
</Base>
