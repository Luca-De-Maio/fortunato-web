---
import { Image } from "astro:assets";
import logoWordmark from "../assets/logo-wordmark.png";
---
<footer class="site-footer">
  <div class="container footer-surface">
    <div class="footer-inner">
      <div class="footer-column footer-brand">
        <a href="/" class="footer-brand-link" aria-label="Fortunato">
          <Image src={logoWordmark} alt="Fortunato" width={3906} height={374} class="footer-wordmark" />
        </a>
        <p class="muted">
          Elegancia moderna. Herencia italo-argentina. Compra directa, atencion personal y una
          capsula pensada para durar.
        </p>
      </div>

      <div class="footer-column">
        <p class="footer-title">Contacto</p>
        <a href="mailto:fortunato.argstore@gmail.com" class="footer-link">fortunato.argstore@gmail.com</a>
        <a href="https://wa.me/5491158204344" class="footer-link">WhatsApp +54 9 11 5820-4344</a>
      </div>

      <div class="footer-column">
        <p class="footer-title">Editorial</p>
        <a href="https://www.instagram.com/fortunato.arg/" class="footer-link" target="_blank" rel="noreferrer">
          Instagram @fortunato.arg
        </a>
        <a href="/#capsula" class="footer-link">Ver capsula completa</a>
      </div>
    </div>

    <div class="footer-bottom">© 2026 Fortunato. Todos los derechos reservados.</div>
  </div>
</footer>
