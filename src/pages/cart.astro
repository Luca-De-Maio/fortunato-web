---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const whatsappNumber = "5491158204344";
---

<Base
  title="Fortunato | Carrito"
  description="Revisá tu selección, validá stock en tiempo real y pagá con Mercado Pago."
>
  <Header />

  <main class="cart-page" id="cart-main" data-analytics-section="cart-main">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Carrito</p>
        <h2>Tu selección Fortunato</h2>
        <p class="muted">El total y el stock se validan desde backend antes de abrir Mercado Pago. Después podés seguir por WhatsApp para coordinar el envío.</p>
      </div>

      <div class="cart-list" data-cart-list></div>

      <div class="cart-summary" data-cart-summary hidden>
        <p><strong>Subtotal de productos</strong>: <span data-cart-subtotal>—</span></p>
        <div class="notice">
          <strong>Checkout seguro:</strong> Al hacer click en pagar, Fortunato vuelve a cotizar tu carrito, reserva stock por unos minutos y abre Mercado Pago con la preference generada desde backend.
        </div>
        <div class="cart-flow" aria-label="Cómo funciona el pago">
          <p><strong>1.</strong> Validamos stock y subtotal en tiempo real.</p>
          <p><strong>2.</strong> Abrís Mercado Pago con el monto exacto del pedido.</p>
          <p><strong>3.</strong> Si querés, seguís por WhatsApp para coordinar envío o cambios.</p>
        </div>
        <p class="muted cart-summary-status" data-cart-status></p>
        <div class="cart-summary-actions">
          <button class="btn" type="button" data-cart-pay data-analytics="cart-pay" data-analytics-kind="button">Ir a pagar con Mercado Pago</button>
          <button class="btn btn-ghost" type="button" data-cart-wa data-analytics="cart-whatsapp" data-analytics-kind="button">Consultar por WhatsApp</button>
          <button class="btn btn-ghost" type="button" data-cart-clear data-analytics="cart-clear" data-analytics-kind="button">Vaciar selección</button>
        </div>
      </div>
    </div>
  </main>

  <Footer />

  <script define:vars={{ whatsappNumber }}>
    const CART_KEY = "fortunato_cart";
    const list = document.querySelector("[data-cart-list]");
    const subtotalEl = document.querySelector("[data-cart-subtotal]");
    const summaryEl = document.querySelector("[data-cart-summary]");
    const clearBtn = document.querySelector("[data-cart-clear]");
    const payBtn = document.querySelector("[data-cart-pay]");
    const waBtn = document.querySelector("[data-cart-wa]");
    const statusEl = document.querySelector("[data-cart-status]");

    let state = {
      cart: [],
      quote: null,
      loading: false
    };

    const getCart = () => {
      try { return JSON.parse(localStorage.getItem(CART_KEY) || "[]"); } catch { return []; }
    };
    const setCart = (cart) => localStorage.setItem(CART_KEY, JSON.stringify(cart));
    const safeImageSrc = (value) => {
      const src = String(value || "").trim();
      if (!src) return "/placeholder.svg";
      if (src.startsWith("/") || /^https?:\/\//i.test(src)) return src;
      return "/placeholder.svg";
    };
    const getMessage = (error, fallback) => {
      if (!error) return fallback;
      if (typeof error === "string") return error;
      if (error instanceof Error && error.message) return error.message;
      return fallback;
    };
    const format = (amount, currency) =>
      typeof amount === "number" && !Number.isNaN(amount)
        ? `${currency} ${amount.toLocaleString("es-AR")}`
        : "Precio a confirmar";

    const makeKey = (item) => `${item.id}__${item.color || ""}__${item.size || ""}`;
    const syncBadge = (cart) => {
      const badge = document.querySelector("[data-cart-count]");
      if (!badge) return;
      const count = (Array.isArray(cart) ? cart : []).reduce((sum, item) => sum + Number(item.qty || 0), 0);
      badge.textContent = count ? String(count) : "";
      badge.classList.toggle("is-visible", count > 0);
    };
    const persistCart = (cart) => {
      state.cart = Array.isArray(cart) ? cart : [];
      setCart(state.cart);
      syncBadge(state.cart);
    };

    const setStatus = (text, type = "") => {
      if (!statusEl) return;
      statusEl.textContent = text || "";
      statusEl.dataset.type = type;
    };
    const createNode = (tag, className, text) => {
      const node = document.createElement(tag);
      if (className) node.className = className;
      if (typeof text === "string") node.textContent = text;
      return node;
    };
    const createCartItem = (item) => {
      const article = createNode("article", "cart-item");
      article.dataset.key = makeKey(item);

      const image = createNode("img");
      image.src = safeImageSrc(item.image);
      image.alt = String(item.name || "Producto Fortunato");
      article.append(image);

      const main = createNode("div", "cart-item-main");
      const top = createNode("div", "cart-item-top");
      const name = createNode("strong", "cart-item-name", String(item.name || "Producto Fortunato"));
      const remove = createNode("button", "cart-remove", "×");
      remove.type = "button";
      remove.setAttribute("data-cart-remove", "");
      remove.setAttribute("aria-label", "Eliminar");
      top.append(name, remove);
      main.append(top);

      if (item.color) {
        main.append(createNode("p", "muted", `Color: ${String(item.color)}`));
      }
      if (item.size) {
        main.append(createNode("p", "muted", `Talle: ${String(item.size)}`));
      }
      if (item.stockLabel) {
        main.append(createNode("p", item.isLowStock ? "cart-stock cart-stock-low" : "cart-stock", String(item.stockLabel)));
      }

      const bottom = createNode("div", "cart-item-bottom");
      const qtyWrap = createNode("div", "cart-qty");
      qtyWrap.setAttribute("aria-label", "Cantidad");
      const dec = createNode("button", "cart-qty-btn", "−");
      dec.type = "button";
      dec.setAttribute("data-cart-dec", "");
      dec.setAttribute("aria-label", "Disminuir");
      const qtyValue = createNode("span", "cart-qty-value", String(item.qty || 1));
      qtyValue.setAttribute("aria-live", "polite");
      const inc = createNode("button", "cart-qty-btn", "+");
      inc.type = "button";
      inc.setAttribute("data-cart-inc", "");
      inc.setAttribute("aria-label", "Aumentar");
      qtyWrap.append(dec, qtyValue, inc);

      const priceBlock = createNode("div", "cart-price-block");
      priceBlock.append(createNode("strong", "cart-line-total", format(Number(item.lineTotal || 0), item.currency || "ARS")));
      if (Number(item.qty || 0) > 1) {
        priceBlock.append(
          createNode("span", "muted cart-each", `(c/u ${format(Number(item.unitPrice || 0), item.currency || "ARS")})`)
        );
      }

      bottom.append(qtyWrap, priceBlock);
      main.append(bottom);
      article.append(main);
      return article;
    };

    const render = () => {
      const cart = Array.isArray(state.cart) ? state.cart : [];
      if (!cart.length) {
        list.replaceChildren(createNode("p", "muted", "Tu selección está vacía."));
        subtotalEl.textContent = "—";
        if (summaryEl) summaryEl.hidden = true;
        if (payBtn) payBtn.disabled = true;
        if (waBtn) waBtn.disabled = true;
        setStatus("");
        return;
      }
      if (summaryEl) summaryEl.hidden = false;
      if (state.loading) {
        list.replaceChildren(createNode("p", "muted", "Validando stock y precios..."));
        if (payBtn) payBtn.disabled = true;
        if (waBtn) waBtn.disabled = true;
        return;
      }
      const quoteItems = Array.isArray(state.quote?.items) ? state.quote.items : [];
      if (!quoteItems.length) {
        list.replaceChildren(createNode("p", "muted", "No pudimos validar tu selección. Probá de nuevo en unos segundos."));
        subtotalEl.textContent = "—";
        if (payBtn) payBtn.disabled = true;
        if (waBtn) waBtn.disabled = true;
        return;
      }
      if (payBtn) payBtn.disabled = false;
      if (waBtn) waBtn.disabled = false;
      const rows = quoteItems.map((item) => createCartItem(item));
      list.replaceChildren(...rows);
      subtotalEl.textContent = format(Number(state.quote?.subtotal || 0), state.quote?.currency || "ARS");
    };

    const buildWhatsappText = (quote, subtotalLabel) => {
      const lines = (quote?.items || []).map((item) => {
        const qty = Number(item.qty || 0);
        const parts = [
          `- ${item.name} x${qty}`,
          item.color ? `Color: ${item.color}` : "",
          item.size ? `Talle: ${item.size}` : "",
          `— ${format(Number(item.lineTotal || 0), item.currency || "ARS")}`
        ].filter(Boolean);
        return parts.join(" · ");
      });

      return [
        "Hola! Quiero confirmar este pedido de Fortunato:",
        "",
        ...lines,
        "",
        `Subtotal validado por la web: ${subtotalLabel}`,
        "",
        "Necesito validar el pago y coordinar el envio."
      ].filter(Boolean).join("\n");
    };

    const requestQuote = async (cart) => {
      const response = await fetch("/api/cart/quote", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ cart })
      });
      if (!response.ok) {
        throw new Error("No pudimos validar el carrito.");
      }
      return response.json();
    };

    const syncQuote = async ({ silent = false } = {}) => {
      const cart = getCart();
      persistCart(cart);
      if (!cart.length) {
        state.quote = null;
        state.loading = false;
        render();
        return null;
      }

      state.loading = true;
      render();
      try {
        const quote = await requestQuote(cart);
        state.quote = quote;
        persistCart(Array.isArray(quote?.cart) ? quote.cart : []);
        state.loading = false;
        render();
        const issues = Array.isArray(quote?.issues) ? quote.issues : [];
        if (issues.length) {
          setStatus(issues.map((issue) => issue.message).slice(0, 2).join(" "), "error");
        } else if (!silent) {
          setStatus("");
        }
        return quote;
      } catch (error) {
        state.loading = false;
        state.quote = null;
        render();
        setStatus(getMessage(error, "No pudimos validar el carrito."), "error");
        return null;
      }
    };

    list?.addEventListener("click", (event) => {
      const row = event.target.closest("[data-key]");
      if (!row) return;
      const key = row.dataset.key;
      const cart = getCart();
      const index = cart.findIndex((item) => makeKey(item) === key);
      if (index === -1) return;

      if (event.target.closest("[data-cart-remove]")) {
        cart.splice(index, 1);
        persistCart(cart);
        syncQuote({ silent: true });
        return;
      }

      if (event.target.closest("[data-cart-inc]")) {
        cart[index].qty = Number(cart[index].qty || 0) + 1;
        persistCart(cart);
        syncQuote({ silent: true });
        return;
      }

      if (event.target.closest("[data-cart-dec]")) {
        const next = Number(cart[index].qty || 0) - 1;
        if (next <= 0) cart.splice(index, 1);
        else cart[index].qty = next;
        persistCart(cart);
        syncQuote({ silent: true });
      }
    });

    clearBtn?.addEventListener("click", () => {
      const cart = getCart();
      if (!cart.length) return;
      if (!confirm("¿Vaciar selección?")) return;
      persistCart([]);
      state.quote = null;
      render();
    });

    payBtn?.addEventListener("click", async () => {
      const quote = await syncQuote({ silent: true });
      if (!quote || !Array.isArray(quote.items) || !quote.items.length) return;
      if (Array.isArray(quote.issues) && quote.issues.length) {
        setStatus("Actualizamos el carrito según el stock disponible. Revisalo antes de pagar.", "error");
        return;
      }

      setStatus("Generando checkout seguro con Mercado Pago...", "pending");
      try {
        const response = await fetch("/api/mercadopago/preference", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ cart: state.cart })
        });
        const payload = await response.json().catch(() => null);
        if (response.status === 409 && payload?.quote) {
          state.quote = payload.quote;
          persistCart(Array.isArray(payload.quote.cart) ? payload.quote.cart : []);
          render();
          setStatus("El stock cambió mientras preparábamos el pago. Ya actualizamos tu carrito.", "error");
          return;
        }
        if (!response.ok || !payload?.checkoutUrl) {
          throw new Error(payload?.error || "No pudimos abrir Mercado Pago.");
        }
        const next = window.open(payload.checkoutUrl, "_blank", "noopener,noreferrer");
        if (!next) window.location.href = payload.checkoutUrl;
        setStatus("Mercado Pago abierto. Tenés unos minutos de reserva sobre este stock.", "pending");
      } catch (error) {
        setStatus(getMessage(error, "No pudimos abrir Mercado Pago."), "error");
      }
    });

    waBtn?.addEventListener("click", () => {
      if (!state.quote?.items?.length) return;
      const subtotalLabel = format(Number(state.quote.subtotal || 0), state.quote.currency || "ARS");
      const text = buildWhatsappText(state.quote, subtotalLabel);
      setStatus("Abriendo WhatsApp...", "pending");
      window.location.href = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(text)}`;
    });

    persistCart(getCart());
    syncQuote();
  </script>
</Base>
