---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const mpEnabled = Boolean((process.env.MERCADOPAGO_ACCESS_TOKEN || "").trim());
const mpAlias = (process.env.PUBLIC_MERCADOPAGO_ALIAS || "").trim();
---

<Base title="Fortunato | Checkout" description={mpEnabled ? "Finalizá tu compra con Mercado Pago o por WhatsApp." : "Finalizá tu compra por WhatsApp."}>
  <Header />

  <main class="checkout-page">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Checkout</p>
        <h2>Finalizá tu compra</h2>
        <p class="muted">Revisá tu pedido y elegí el canal para pagar.</p>
      </div>

      <div class="checkout-grid">
        <section class="checkout-card" aria-label="Resumen del pedido">
          <h3>Tu pedido</h3>
          <div class="checkout-list" data-checkout-list></div>
          <div class="checkout-total">
            <p><strong>Subtotal</strong></p>
            <p class="checkout-total-amount" data-checkout-subtotal>—</p>
            <p class="muted" style="margin-top: 0.25rem;">Envío e impuestos se calculan luego de confirmar.</p>
          </div>
        </section>

        <section class="checkout-card" aria-label="Acciones de pago">
          <h3>Pagos</h3>
          <p class="muted">
            {mpEnabled ? "Mercado Pago para pagar al instante. WhatsApp para atención personalizada." : "Comprá por WhatsApp y coordinamos el pago y el envío."}
          </p>
          <div class="checkout-actions">
            {mpEnabled ? (
              <button class="btn" type="button" data-mp-pay disabled>Pagar con Mercado Pago</button>
            ) : null}
            <button class="btn btn-ghost" type="button" data-wa-pay disabled>Comprar por WhatsApp</button>
            {mpAlias ? (
              <button class="btn btn-ghost" type="button" data-copy-alias>Copiar alias Mercado Pago</button>
            ) : null}
            <p class="muted checkout-status" data-checkout-status></p>
          </div>

          {mpEnabled ? (
            <div class="notice" style="margin-top: 1.1rem;">
              <strong>Cuotas:</strong> 3 cuotas sin interés · 6 cuotas con interés (Mercado Pago)
            </div>
          ) : (
            <div class="notice" style="margin-top: 1.1rem;">
              <strong>Pago:</strong> Coordinamos por WhatsApp.
            </div>
          )}

          {mpAlias ? (
            <div class="notice" style="margin-top: 1rem;">
              <strong>Alias Mercado Pago:</strong> {mpAlias}
            </div>
          ) : null}
        </section>
      </div>
    </div>
  </main>

  <Footer />

  <script define:vars={{ mpEnabled, mpAlias }}>
    const CART_KEY = "fortunato_cart";
    const listEl = document.querySelector("[data-checkout-list]");
    const subtotalEl = document.querySelector("[data-checkout-subtotal]");
    const statusEl = document.querySelector("[data-checkout-status]");
    const mpBtn = document.querySelector("[data-mp-pay]");
    const waBtn = document.querySelector("[data-wa-pay]");
    const copyAliasBtn = document.querySelector("[data-copy-alias]");

    const getCart = () => {
      try { return JSON.parse(localStorage.getItem(CART_KEY) || "[]"); } catch { return []; }
    };

    const format = (amount, currency) =>
      typeof amount === "number" && !Number.isNaN(amount)
        ? `${currency} ${amount.toLocaleString("es-AR")}`
        : "—";

    const render = () => {
      const cart = getCart();
      if (!cart.length) {
        listEl.innerHTML = "<p class='muted'>Tu carrito está vacío.</p>";
        subtotalEl.textContent = "—";
        if (mpBtn) mpBtn.disabled = true;
        waBtn.disabled = true;
        return;
      }

      let subtotal = 0;
      listEl.innerHTML = cart.map((item) => {
        const qty = Number(item.qty || 0);
        const price = Number(item.price || 0);
        const line = price * qty;
        subtotal += line;
        const color = item.color ? ` · ${item.color}` : "";
        const size = item.size ? ` · Talle ${item.size}` : "";
        return `
          <article class="checkout-item">
            <img src="${item.image || "/placeholder.svg"}" alt="${item.name}" />
            <div class="checkout-item-main">
              <strong>${item.name}</strong>
              <p class="muted">${qty} × ${format(price, item.currency || "ARS")}${color}${size}</p>
            </div>
            <div class="checkout-item-total"><strong>${format(line, item.currency || "ARS")}</strong></div>
          </article>
        `;
      }).join("");

      subtotalEl.textContent = format(subtotal, cart[0]?.currency || "ARS");
      if (mpBtn) mpBtn.disabled = false;
      waBtn.disabled = false;
    };

    const setStatus = (text, type = "") => {
      if (!statusEl) return;
      statusEl.textContent = text || "";
      statusEl.dataset.type = type;
    };

    const createPreference = async (cart) => {
      const res = await fetch("/api/mercadopago/preference", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ cart })
      });
      if (!res.ok) {
        const msg = await res.text().catch(() => "No se pudo crear el link de pago.");
        throw new Error(msg);
      }
      return res.json();
    };

    const buildWhatsappText = (cart, totalLabel, checkoutUrl, alias) => {
      const lines = cart.map((item) => {
        const qty = Number(item.qty || 0);
        const price = Number(item.price || 0);
        const lineTotal = price * qty;
        const parts = [
          `- ${item.name} x${qty}`,
          item.color ? `Color: ${item.color}` : "",
          item.size ? `Talle: ${item.size}` : "",
          `— ${format(lineTotal, item.currency || "ARS")}`
        ].filter(Boolean);
        return parts.join(" · ");
      });

      const out = [
        "Hola! Quiero comprar:",
        "",
        ...lines,
        "",
        `Total: ${totalLabel}`,
        checkoutUrl ? `Link de pago (Mercado Pago): ${checkoutUrl}` : "",
        alias ? `Alias Mercado Pago: ${alias}` : ""
      ].filter(Boolean);

      return out.join("\n");
    };

    mpBtn?.addEventListener("click", async () => {
      const cart = getCart();
      if (!cart.length) return;
      if (mpBtn) mpBtn.disabled = true;
      waBtn.disabled = true;
      setStatus("Generando link de pago...", "pending");
      try {
        const data = await createPreference(cart);
        if (!data?.checkoutUrl) throw new Error("No se recibió el link de pago.");
        window.location.href = data.checkoutUrl;
      } catch (err) {
        setStatus(err?.message || "No se pudo iniciar Mercado Pago.", "error");
        if (mpBtn) mpBtn.disabled = false;
        waBtn.disabled = false;
      }
    });

    waBtn?.addEventListener("click", async () => {
      const cart = getCart();
      if (!cart.length) return;

      waBtn.disabled = true;
      if (mpBtn) mpBtn.disabled = true;
      setStatus("Preparando mensaje...", "pending");

      // Total visible.
      const total = cart.reduce((sum, item) => sum + Number(item.price || 0) * Number(item.qty || 0), 0);
      const totalLabel = format(total, cart[0]?.currency || "ARS");
      let checkoutUrl = "";
      if (mpEnabled) {
        try {
          const data = await createPreference(cart);
          checkoutUrl = data?.checkoutUrl || "";
        } catch {}
      }

      const text = buildWhatsappText(cart, totalLabel, checkoutUrl, mpAlias);
      const phone = "5491158204344";
      const url = `https://wa.me/${phone}?text=${encodeURIComponent(text)}`;
      window.location.href = url;
    });

    copyAliasBtn?.addEventListener("click", async () => {
      if (!mpAlias) return;
      try {
        await navigator.clipboard.writeText(mpAlias);
        setStatus("Alias copiado.", "pending");
      } catch {
        setStatus("No se pudo copiar el alias.", "error");
      }
    });

    render();
  </script>
</Base>
