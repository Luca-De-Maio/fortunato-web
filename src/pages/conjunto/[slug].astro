---
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { getCombinationAvailabilitySnapshot } from "../../lib/commerce";
import { getCombinationBySlug } from "../../lib/combinations";

export const prerender = false;

const { slug } = Astro.params;
const combo = await getCombinationBySlug(slug);
if (!combo) {
  throw new Response(null, { status: 404, statusText: "Not found" });
}

const comboAvailabilitySnapshot = await getCombinationAvailabilitySnapshot(combo);
const comboAvailableQty = Number(comboAvailabilitySnapshot.availableQty || 0);
const comboInStock = Boolean(comboAvailabilitySnapshot.inStock);
const comboItemsWithAvailability = combo.items.map((item) => {
  const availability = comboAvailabilitySnapshot.items.find((entry: any) =>
    String(entry?.id || "") === String(item.id || "") &&
    String(entry?.color || "") === String(item.color || "")
  );

  return {
    ...item,
    stock: Array.isArray(availability?.stock) ? availability.stock : [],
    totalAvailable: Number(availability?.totalAvailable || 0),
    inStock: Boolean(availability?.inStock)
  };
});
const comboRequiresSelection = comboItemsWithAvailability.some((item) => Array.isArray(item.sizes) && item.sizes.length > 0);
const comboStockLabel =
  !comboInStock
    ? "Sin stock suficiente para armar este conjunto."
    : comboAvailableQty <= 2
      ? `Ultimos ${comboAvailableQty} conjuntos disponibles.`
      : "Stock disponible para armar este conjunto.";
const comboInitialCtaLabel =
  !comboInStock
    ? "Sin stock"
    : comboRequiresSelection
      ? "Elegi los talles"
      : "Agregar conjunto al carrito";

const comboBuilderItems = comboItemsWithAvailability.map((item) => ({
  id: item.id,
  name: item.name,
  color: item.color || "",
  sizes: Array.isArray(item.sizes) ? item.sizes : [],
  stock: Array.isArray(item.stock)
    ? item.stock.map((entry: any) => ({
      size: String(entry?.size || ""),
      available: Number(entry?.available || 0)
    }))
    : [],
  totalAvailable: Number(item.totalAvailable || 0)
}));

const formatPrice = (value: number, currency: string) =>
  `${currency} ${value.toLocaleString("es-AR")}`;
---

<Base title={`Fortunato | ${combo.title}`} description={combo.notes || `Comprá ${combo.title} completo en Fortunato.`}>
  <Header />

  <main class="combo-page">
    <section id="combo-detalle" class="section combo-section" data-analytics-section="combo-detalle">
      <div class="container combo-layout">
        <div class="combo-media-card">
          <img src={combo.image || "/placeholder.svg"} alt={combo.title} width="1200" height="1500" decoding="async" />
        </div>

        <div class="combo-summary-card" data-combo-builder>
          <p class="eyebrow">Conjunto Fortunato</p>
          <h1>{combo.title}</h1>
          {combo.notes ? <p class="combo-lead">{combo.notes}</p> : null}

          <div class="combo-pricing">
            <p class="combo-price">{formatPrice(combo.bundlePrice, combo.currency)}</p>
            {combo.savingsAmount > 0 ? (
              <p class="combo-compare">
                <span>{formatPrice(combo.regularPrice, combo.currency)}</span>
                <span class="discount-pill">{combo.savingsPercent}% OFF</span>
              </p>
            ) : null}
            <p class:list={{ "combo-stock": true, "is-low": comboInStock && comboAvailableQty <= 2, "is-out": !comboInStock }} data-combo-stock>{comboStockLabel}</p>
          </div>

          <section class="combo-includes" aria-label="Qué incluye">
            <div class="combo-block-head">
              <h2>Qué incluye</h2>
              <p class="muted">Elegí el talle de cada prenda del look antes de sumarlo al carrito.</p>
            </div>

            <ul class="combo-item-list">
              {comboItemsWithAvailability.map((item) => (
                <li class="combo-item-card" data-combo-item-card={item.id}>
                  <a href={`/product/${item.slug}`} class="combo-item-media" aria-label={`Ver ${item.name}`}>
                    <img src={item.image || "/placeholder.svg"} alt={item.name} width="240" height="300" loading="lazy" decoding="async" />
                  </a>

                  <div class="combo-item-copy">
                    <div class="combo-item-head">
                      <a href={`/product/${item.slug}`} class="combo-item-name">{item.name}</a>
                      <p class="combo-item-price">{formatPrice(item.price, item.currency)}</p>
                    </div>

                    {item.microcopy?.trim() ? (
                      <p class="muted">{item.microcopy}</p>
                    ) : item.materials?.length ? (
                      <p class="muted">{item.materials.slice(0, 2).join(" · ")}</p>
                    ) : null}

                    <div class="combo-item-meta">
                      {item.color ? <span class="combo-item-pill">Color {item.color}</span> : null}
                      {!item.inStock ? <span class="combo-item-pill is-out">Sin stock</span> : null}
                      {item.inStock && item.totalAvailable <= 2 ? (
                        <span class="combo-item-pill is-low">Ultimos {item.totalAvailable}</span>
                      ) : null}
                    </div>

                    {item.sizes?.length ? (
                      <div class="combo-item-picker">
                        <p class="combo-item-picker-label">Talle</p>
                        <ul class="combo-size-grid" aria-label={`Talles para ${item.name}`}>
                          {item.sizes.map((size) => {
                            const stockEntry = item.stock.find((entry) => String(entry?.size || "") === String(size));
                            const available = Number(stockEntry?.available || 0);
                            return (
                              <li>
                                <button
                                  type="button"
                                  class="combo-size"
                                  data-combo-size-option={size}
                                  data-combo-item-id={item.id}
                                  aria-pressed="false"
                                  disabled={available <= 0}
                                >
                                  {size}
                                </button>
                              </li>
                            );
                          })}
                        </ul>
                        <p class="combo-item-hint muted" data-combo-item-hint={item.id}>Elegí el talle de esta prenda.</p>
                      </div>
                    ) : (
                      <p class="combo-item-hint muted">Esta prenda entra en el conjunto sin selección adicional.</p>
                    )}
                  </div>
                </li>
              ))}
            </ul>
          </section>

          <div class="combo-cta-stack">
            <button
              class="btn"
              type="button"
              data-combo-add
              data-analytics="combo-add-to-cart"
              data-analytics-kind="button"
              disabled={!comboInStock || comboRequiresSelection}
            >
              {comboInitialCtaLabel}
            </button>
            <button
              class="btn btn-ghost"
              type="button"
              data-combo-buy
              data-analytics="combo-buy-now"
              data-analytics-kind="button"
              disabled={!comboInStock || comboRequiresSelection}
            >
              Comprar ahora
            </button>
            <p class="muted combo-feedback" data-combo-feedback></p>
          </div>

          <div class="notice">
            <strong>Pedido y envío:</strong> Validamos el stock antes del pago y después podés seguir por WhatsApp para coordinar el envío.
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />

  <script define:vars={{
    comboBuilderItems,
    comboId: combo.id,
    comboTitle: combo.title,
    comboImage: combo.image || "/placeholder.svg",
    comboInStock,
    comboAvailableQty,
    comboStockLabel,
    comboRequiresSelection
  }}>
    const root = document.querySelector("[data-combo-builder]");

    if (root) {
      const addButton = root.querySelector("[data-combo-add]");
      const buyButton = root.querySelector("[data-combo-buy]");
      const stockNote = root.querySelector("[data-combo-stock]");
      const feedback = root.querySelector("[data-combo-feedback]");
      const sizeButtons = Array.from(root.querySelectorAll("[data-combo-size-option]"));
      const hintNodes = Array.from(root.querySelectorAll("[data-combo-item-hint]"));
      const items = Array.isArray(comboBuilderItems) ? comboBuilderItems : [];
      const selectedSizes = new Map();
      const hintByItemId = new Map(
        hintNodes.map((node) => [node.dataset.comboItemHint || "", node])
      );
      const normalize = (value) => String(value || "").trim().toLowerCase();
      const defaultAddLabel = !comboInStock
        ? "Sin stock"
        : comboRequiresSelection
          ? "Elegi los talles"
          : "Agregar conjunto al carrito";

      const getItem = (itemId) =>
        items.find((item) => normalize(item.id) === normalize(itemId)) || null;

      const getAvailabilityFor = (itemId, size) => {
        const item = getItem(itemId);
        if (!item) return 0;
        const match = (item.stock || []).find((entry) => normalize(entry.size) === normalize(size));
        return Number(match?.available || 0);
      };

      const setFeedback = (text, type = "") => {
        if (!feedback) return;
        feedback.textContent = text || "";
        feedback.dataset.type = type;
      };

      const getSelectedAvailability = () => {
        const variantItems = items.filter((item) => Array.isArray(item.sizes) && item.sizes.length > 0);
        if (!variantItems.length) return Number(comboAvailableQty || 0);
        return Math.min(...variantItems.map((item) => getAvailabilityFor(item.id, selectedSizes.get(item.id) || "")));
      };

      const hasAllRequiredSizes = () =>
        items.every((item) => !Array.isArray(item.sizes) || !item.sizes.length || Boolean(selectedSizes.get(item.id)));

      const updateHint = (itemId) => {
        const hint = hintByItemId.get(itemId);
        if (!hint) return;
        const size = selectedSizes.get(itemId) || "";
        if (!size) {
          hint.textContent = "Elegí el talle de esta prenda.";
          return;
        }

        const available = getAvailabilityFor(itemId, size);
        if (available <= 0) {
          hint.textContent = `El talle ${size} está sin stock.`;
          return;
        }

        hint.textContent = available <= 2
          ? `Talle ${size} elegido. Quedan ${available}.`
          : `Talle ${size} elegido.`;
      };

      const updateButtons = () => {
        const ready = hasAllRequiredSizes();
        const selectedAvailability = ready ? getSelectedAvailability() : 0;
        const canBuy = comboInStock && (!comboRequiresSelection || (ready && selectedAvailability > 0));

        if (addButton) {
          addButton.disabled = !canBuy;
          addButton.textContent = !comboInStock
            ? "Sin stock"
            : !ready
              ? "Elegi los talles"
              : selectedAvailability <= 0
                ? "Sin stock"
                : "Agregar conjunto al carrito";
        }

        if (buyButton) {
          buyButton.disabled = !canBuy;
        }

        if (stockNote && comboInStock) {
          if (!ready) {
            stockNote.textContent = comboStockLabel;
            stockNote.classList.toggle("is-low", comboAvailableQty > 0 && comboAvailableQty <= 2);
            stockNote.classList.remove("is-out");
            return;
          }

          if (selectedAvailability <= 0) {
            stockNote.textContent = "La combinación de talles elegida está sin stock.";
            stockNote.classList.add("is-out");
            stockNote.classList.remove("is-low");
            return;
          }

          stockNote.textContent = selectedAvailability <= 2
            ? `Ultimos ${selectedAvailability} conjuntos disponibles con esta selección.`
            : "Selección lista para agregar al carrito.";
          stockNote.classList.toggle("is-low", selectedAvailability <= 2);
          stockNote.classList.remove("is-out");
        }
      };

      const setSize = (itemId, value) => {
        selectedSizes.set(itemId, value);

        sizeButtons.forEach((button) => {
          if ((button.dataset.comboItemId || "") !== itemId) return;
          const isSelected = (button.dataset.comboSizeOption || "") === value;
          button.classList.toggle("is-selected", isSelected);
          button.setAttribute("aria-pressed", isSelected ? "true" : "false");
        });

        updateHint(itemId);
        setFeedback("");
        updateButtons();
      };

      const buildPayload = () => {
        if (comboRequiresSelection && !hasAllRequiredSizes()) {
          setFeedback("Elegí el talle de cada prenda para continuar.", "error");
          return null;
        }

        const components = items.map((item) => ({
          productId: item.id,
          color: String(item.color || ""),
          size: Array.isArray(item.sizes) && item.sizes.length ? String(selectedSizes.get(item.id) || "") : ""
        }));

        return {
          id: `combo-${comboId}`,
          name: comboTitle,
          image: comboImage,
          components
        };
      };

      const addComboToCart = (payload) => {
        if (window.FortunatoCart?.addItem) {
          window.FortunatoCart.addItem(payload);
          return;
        }

        const CART_KEY = "fortunato_cart";
        const raw = (() => {
          try {
            return JSON.parse(localStorage.getItem(CART_KEY) || "[]");
          } catch {
            return [];
          }
        })();
        raw.push({ ...payload, qty: 1 });
        localStorage.setItem(CART_KEY, JSON.stringify(raw));
      };

      sizeButtons.forEach((button) => {
        button.addEventListener("click", () => {
          setSize(button.dataset.comboItemId || "", button.dataset.comboSizeOption || "");
        });
      });

      addButton?.addEventListener("click", () => {
        const payload = buildPayload();
        if (!payload) return;
        addComboToCart(payload);
        setFeedback("Conjunto agregado al carrito.", "success");
        const previousLabel = addButton.textContent;
        addButton.textContent = "Agregado";
        window.setTimeout(() => {
          addButton.textContent = previousLabel || defaultAddLabel;
        }, 1200);
      });

      buyButton?.addEventListener("click", () => {
        const payload = buildPayload();
        if (!payload) return;
        addComboToCart(payload);
        window.location.href = "/cart";
      });

      hintByItemId.forEach((_, itemId) => updateHint(itemId));
      updateButtons();
    }
  </script>
</Base>

<style>
  .combo-page {
    padding-bottom: 4.5rem;
  }

  .combo-section {
    padding-top: 2.75rem;
  }

  .combo-layout {
    display: grid;
    gap: 2rem;
    grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.95fr);
    align-items: start;
  }

  .combo-media-card,
  .combo-summary-card {
    background: var(--white);
    border-radius: 24px;
    border: 1px solid rgba(24, 74, 69, 0.1);
    box-shadow: var(--shadow);
    overflow: hidden;
  }

  .combo-media-card img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
    image-orientation: from-image;
  }

  .combo-summary-card {
    padding: 2rem;
    display: grid;
    gap: 1.4rem;
  }

  .combo-summary-card h1 {
    font-family: "Cinzel", "Cormorant Garamond", serif;
    font-size: clamp(2rem, 3vw, 3rem);
    line-height: 1.04;
    color: var(--green);
  }

  .combo-lead {
    margin-top: -0.3rem;
    color: rgba(64, 67, 66, 0.88);
    font-size: 1rem;
  }

  .combo-pricing {
    display: grid;
    gap: 0.35rem;
    padding: 1rem 1.1rem;
    background: rgba(245, 232, 215, 0.38);
    border-radius: 18px;
    border: 1px solid rgba(24, 74, 69, 0.08);
  }

  .combo-price {
    font-size: 1.8rem;
    font-weight: 800;
    color: var(--green);
  }

  .combo-compare {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    align-items: center;
    color: rgba(64, 67, 66, 0.72);
  }

  .combo-compare span:first-child {
    text-decoration: line-through;
  }

  .combo-installments {
    margin-top: 0.2rem;
  }

  .combo-stock {
    margin-top: 0.3rem;
    font-size: 0.92rem;
    color: rgba(40, 44, 43, 0.82);
  }

  .combo-stock.is-low {
    color: #8a5f1f;
  }

  .combo-stock.is-out {
    color: #8c2f2f;
  }

  .combo-includes {
    display: grid;
    gap: 0.9rem;
  }

  .combo-block-head {
    display: grid;
    gap: 0.2rem;
  }

  .combo-block-head h2 {
    font-family: "Outfit", system-ui, sans-serif;
    font-size: 1.15rem;
    color: var(--ink);
  }

  .combo-item-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.85rem;
  }

  .combo-item-card {
    display: grid;
    grid-template-columns: 88px 1fr;
    gap: 0.85rem;
    align-items: start;
    padding: 0.9rem;
    border-radius: 18px;
    border: 1px solid rgba(24, 74, 69, 0.08);
    background: rgba(245, 232, 215, 0.24);
  }

  .combo-item-media img {
    width: 88px;
    height: 110px;
    object-fit: cover;
    border-radius: 14px;
    image-orientation: from-image;
  }

  .combo-item-copy {
    display: grid;
    gap: 0.55rem;
  }

  .combo-item-head {
    display: flex;
    justify-content: space-between;
    gap: 0.75rem;
    align-items: baseline;
  }

  .combo-item-name {
    font-weight: 600;
    color: var(--ink);
  }

  .combo-item-price {
    margin: 0;
    font-weight: 700;
    color: var(--green);
    white-space: nowrap;
  }

  .combo-item-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .combo-item-pill {
    display: inline-flex;
    align-items: center;
    padding: 0.28rem 0.7rem;
    border-radius: 999px;
    background: rgba(24, 74, 69, 0.08);
    color: var(--green);
    font-size: 0.76rem;
    font-weight: 600;
  }

  .combo-item-pill.is-low {
    background: rgba(138, 95, 31, 0.14);
    color: #8a5f1f;
  }

  .combo-item-pill.is-out {
    background: rgba(140, 47, 47, 0.12);
    color: #8c2f2f;
  }

  .combo-item-picker {
    display: grid;
    gap: 0.45rem;
  }

  .combo-item-picker-label {
    margin: 0;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(40, 44, 43, 0.72);
  }

  .combo-size-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .combo-size {
    min-width: 4.25rem;
    padding: 0.68rem 0.9rem;
    border-radius: 999px;
    border: 1px solid rgba(24, 74, 69, 0.14);
    background: var(--white);
    color: var(--ink);
    font: inherit;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: transform 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
  }

  .combo-size:active {
    transform: translateY(1px);
  }

  .combo-size.is-selected {
    background: var(--green);
    border-color: var(--green);
    color: var(--white);
    box-shadow: 0 12px 26px rgba(24, 74, 69, 0.18);
  }

  .combo-size:disabled {
    cursor: not-allowed;
    opacity: 0.45;
    box-shadow: none;
  }

  .combo-item-hint,
  .combo-feedback {
    margin: 0;
    font-size: 0.9rem;
  }

  .combo-feedback[data-type="error"] {
    color: #8c2f2f;
  }

  .combo-feedback[data-type="success"] {
    color: var(--green);
  }

  .combo-cta-stack {
    display: grid;
    gap: 0.7rem;
  }

  @media (max-width: 960px) {
    .combo-layout {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 760px) {
    .combo-section {
      padding-top: 1.35rem;
    }

    .combo-summary-card {
      padding: 1.2rem;
      gap: 1rem;
    }

    .combo-item-card {
      grid-template-columns: 72px 1fr;
      gap: 0.7rem;
    }

    .combo-item-media img {
      width: 72px;
      height: 92px;
    }

    .combo-item-head {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.2rem;
    }
  }
</style>
