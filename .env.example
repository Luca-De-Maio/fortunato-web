## Fortunato (Railway)
## Copiá a `.env` en local, o cargalo como Variables en Railway.

# Admin
ADMIN_USER=sofihermosa
# Recomendado (hash bcrypt): `npm run hash:password -- <password>`
ADMIN_PASSWORD_HASH=
# Alternativa (menos seguro): contraseña en texto plano (no usar en prod)
ADMIN_PASSWORD=
# Fallback dev solo si querés habilitar explícitamente las credenciales locales de emergencia
ALLOW_DEV_ADMIN_FALLBACK=false
# Sesiones (en prod, poné un string largo aleatorio)
SESSION_SECRET=

# Si más adelante volvés a habilitar uploads, hacelo con firma server-side.
# No expongas presets unsigned en producción.

# SQLite (persistencia: usar Railway Volume y apuntar acá)
DB_PATH=/data/fortunato.db

# Mercado Pago (server-side)
MERCADOPAGO_ACCESS_TOKEN=
# prod | sandbox
MERCADOPAGO_ENV=prod
# Link publico de fallback para cobrar el subtotal del carrito
PUBLIC_MERCADOPAGO_PAYMENT_LINK=https://link.mercadopago.com.ar/tiendafortunato
# Alias visible en checkout y páginas de conjunto
PUBLIC_MERCADOPAGO_ALIAS=
# Opcional: URL pública para back_urls (si no, se toma del request)
PUBLIC_SITE_URL=
