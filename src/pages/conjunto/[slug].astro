---
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { quoteCart } from "../../lib/commerce";
import { getCombinationBySlug } from "../../lib/combinations";

export const prerender = false;

const { slug } = Astro.params;
const combo = await getCombinationBySlug(slug);
if (!combo) {
  throw new Response(null, { status: 404, statusText: "Not found" });
}
const comboQuote = await quoteCart([{ id: `combo-${combo.id}`, qty: 1 }]);
const comboAvailability = Number(comboQuote.items?.[0]?.availableQty || 0);
const comboInStock = comboAvailability > 0;
const comboStockLabel =
  !comboInStock
    ? "Sin stock suficiente para armar este conjunto."
    : comboAvailability <= 2
      ? `Últimos ${comboAvailability} conjuntos disponibles.`
      : "Stock disponible para armar este conjunto.";

const formatPrice = (value: number, currency: string) =>
  `${currency} ${value.toLocaleString("es-AR")}`;
---

<Base title={`Fortunato | ${combo.title}`} description={combo.notes || `Comprá ${combo.title} completo en Fortunato.`}>
  <Header />

  <main class="combo-page">
    <section id="combo-detalle" class="section combo-section" data-analytics-section="combo-detalle">
      <div class="container combo-layout">
        <div class="combo-media-card">
          <img src={combo.image || "/placeholder.svg"} alt={combo.title} width="1200" height="1500" decoding="async" />
        </div>

        <div class="combo-summary-card">
          <p class="eyebrow">Conjunto Fortunato</p>
          <h1>{combo.title}</h1>
          {combo.notes ? <p class="combo-lead">{combo.notes}</p> : null}

          <div class="combo-pricing">
            <p class="combo-price">{formatPrice(combo.bundlePrice, combo.currency)}</p>
            {combo.savingsAmount > 0 ? (
              <p class="combo-compare">
                <span>{formatPrice(combo.regularPrice, combo.currency)}</span>
                <span class="discount-pill">{combo.savingsPercent}% OFF</span>
              </p>
            ) : null}
            <p class="muted combo-installments">Pagás dentro de Mercado Pago con subtotal validado desde backend.</p>
            <p class:list={{ "combo-stock": true, "is-low": comboInStock && comboAvailability <= 2, "is-out": !comboInStock }}>{comboStockLabel}</p>
          </div>

          <section class="combo-includes" aria-label="Qué incluye">
            <div class="combo-block-head">
              <h2>Qué incluye</h2>
              <p class="muted">Podés revisar cada prenda por separado antes de comprar el conjunto.</p>
            </div>

            <ul class="combo-item-list">
              {combo.items.map((item) => (
                <li class="combo-item-card">
                  <a href={`/product/${item.slug}`} class="combo-item-media" aria-label={`Ver ${item.name}`}>
                    <img src={item.image || "/placeholder.svg"} alt={item.name} width="240" height="300" loading="lazy" decoding="async" />
                  </a>
                  <div class="combo-item-copy">
                    <a href={`/product/${item.slug}`} class="combo-item-name">{item.name}</a>
                    {item.microcopy?.trim() ? (
                      <p class="muted">{item.microcopy}</p>
                    ) : item.materials?.length ? (
                      <p class="muted">{item.materials.slice(0, 2).join(" · ")}</p>
                    ) : null}
                    <p class="combo-item-price">{formatPrice(item.price, item.currency)}</p>
                  </div>
                </li>
              ))}
            </ul>
          </section>

          <div class="combo-cta-stack">
            <button
              class="btn"
              data-add-to-cart
              data-analytics="combo-add-to-cart"
              data-analytics-kind="button"
              data-id={`combo-${combo.id}`}
              data-name={combo.title}
              data-image={combo.image || "/placeholder.svg"}
              disabled={!comboInStock}
            >
              {comboInStock ? "Agregar conjunto al carrito" : "Sin stock"}
            </button>
            <button
              class="btn btn-ghost"
              type="button"
              data-buy-now
              data-analytics="combo-buy-now"
              data-analytics-kind="button"
              data-id={`combo-${combo.id}`}
              data-name={combo.title}
              data-image={combo.image || "/placeholder.svg"}
              disabled={!comboInStock}
            >
              Comprar ahora
            </button>
          </div>

          <div class="notice">
            <strong>Pedido y envío:</strong> Validamos el stock antes del pago y después podés seguir por WhatsApp para coordinar el envío.
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Base>

<style>
  .combo-page {
    padding-bottom: 4.5rem;
  }

  .combo-section {
    padding-top: 2.75rem;
  }

  .combo-layout {
    display: grid;
    gap: 2rem;
    grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.95fr);
    align-items: start;
  }

  .combo-media-card,
  .combo-summary-card {
    background: var(--white);
    border-radius: 24px;
    border: 1px solid rgba(24, 74, 69, 0.1);
    box-shadow: var(--shadow);
    overflow: hidden;
  }

  .combo-media-card img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
    image-orientation: from-image;
  }

  .combo-summary-card {
    padding: 2rem;
    display: grid;
    gap: 1.4rem;
  }

  .combo-summary-card h1 {
    font-family: "Cinzel", "Cormorant Garamond", serif;
    font-size: clamp(2rem, 3vw, 3rem);
    line-height: 1.04;
    color: var(--green);
  }

  .combo-lead {
    margin-top: -0.3rem;
    color: rgba(64, 67, 66, 0.88);
    font-size: 1rem;
  }

  .combo-pricing {
    display: grid;
    gap: 0.35rem;
    padding: 1rem 1.1rem;
    background: rgba(245, 232, 215, 0.38);
    border-radius: 18px;
    border: 1px solid rgba(24, 74, 69, 0.08);
  }

  .combo-price {
    font-size: 1.8rem;
    font-weight: 800;
    color: var(--green);
  }

  .combo-compare {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    align-items: center;
    color: rgba(64, 67, 66, 0.72);
  }

  .combo-compare span:first-child {
    text-decoration: line-through;
  }

  .combo-installments {
    margin-top: 0.2rem;
  }

  .combo-stock {
    margin-top: 0.3rem;
    font-size: 0.92rem;
    color: rgba(40, 44, 43, 0.82);
  }

  .combo-stock.is-low {
    color: #8a5f1f;
  }

  .combo-stock.is-out {
    color: #8c2f2f;
  }

  .combo-includes {
    display: grid;
    gap: 0.9rem;
  }

  .combo-block-head {
    display: grid;
    gap: 0.2rem;
  }

  .combo-block-head h2 {
    font-family: "Outfit", system-ui, sans-serif;
    font-size: 1.15rem;
    color: var(--ink);
  }

  .combo-item-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.85rem;
  }

  .combo-item-card {
    display: grid;
    grid-template-columns: 88px 1fr;
    gap: 0.85rem;
    align-items: center;
    padding: 0.8rem;
    border-radius: 18px;
    border: 1px solid rgba(24, 74, 69, 0.08);
    background: rgba(245, 232, 215, 0.24);
  }

  .combo-item-media img {
    width: 88px;
    height: 110px;
    object-fit: cover;
    border-radius: 14px;
    image-orientation: from-image;
  }

  .combo-item-copy {
    display: grid;
    gap: 0.22rem;
  }

  .combo-item-name {
    font-weight: 600;
    color: var(--ink);
  }

  .combo-item-price {
    margin-top: 0.2rem;
    font-weight: 700;
    color: var(--green);
  }

  .combo-cta-stack {
    display: grid;
    gap: 0.7rem;
  }

  @media (max-width: 960px) {
    .combo-layout {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 760px) {
    .combo-section {
      padding-top: 1.35rem;
    }

    .combo-summary-card {
      padding: 1.2rem;
      gap: 1rem;
    }

    .combo-item-card {
      grid-template-columns: 72px 1fr;
      gap: 0.7rem;
    }

    .combo-item-media img {
      width: 72px;
      height: 92px;
    }

  }
</style>
