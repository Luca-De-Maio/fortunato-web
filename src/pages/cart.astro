---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Base from "../layouts/Base.astro";
import { ARGENTINA_PROVINCES, CHECKOUT_LIMITS } from "../lib/checkout";

const whatsappNumber = "5491158204344";
const mercadoPagoPublicKey = import.meta.env.PUBLIC_MERCADOPAGO_PUBLIC_KEY || "";
const checkoutConfig = {
  limits: CHECKOUT_LIMITS,
  patterns: {
    fullName: "[A-Za-zÁÉÍÓÚÜÑáéíóúüñ]+(?:[ '.-][A-Za-zÁÉÍÓÚÜÑáéíóúüñ]+)+",
    postalCode: "(?:\\d{4}|[A-Z]\\d{4}[A-Z]{3})",
    streetNumber: "[A-Za-z0-9/-]{1,10}"
  }
};
---

<Base
  title="Fortunato | Carrito"
  description="Revisá tu selección, completá tus datos de entrega y pagá de forma segura con Mercado Pago."
>
  <Header />

  <main class="cart-page" id="cart-main" data-analytics-section="cart-main">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Carrito</p>
        <h2>Tu selección Fortunato</h2>
        <p class="muted">Completá tus datos de entrega y pagá las prendas. El costo de envío te lo confirmamos después.</p>
      </div>

      <div class="cart-layout">
        <div class="cart-list-wrap">
          <div class="cart-list" data-cart-list></div>
        </div>

        <div class="cart-summary-wrap">
          <div class="cart-summary" data-cart-summary hidden>
            <div class="cart-summary-top">
              <p class="cart-summary-eyebrow">Resumen de compra</p>
              <div class="cart-summary-price">
                <p class="cart-summary-total-label">Pagás ahora</p>
                <p class="cart-summary-total-amount" data-cart-total>—</p>
              </div>
              <div class="cart-summary-breakdown" aria-label="Resumen del pedido">
                <p><span>Prendas</span><strong data-cart-subtotal>—</strong></p>
                <p><span>Envío</span><strong data-cart-shipping>A confirmar</strong></p>
              </div>
              <div class="cart-summary-hint" data-cart-shipping-copy>
                Completá tus datos de entrega. El costo de envío se confirma después de la compra.
              </div>
            </div>

            <form class="cart-checkout-form" data-cart-checkout-form>
              <section class="cart-form-section">
                <div class="cart-form-head">
                  <p class="cart-form-eyebrow">Contacto</p>
                  <h3>Datos para tu compra</h3>
                </div>
                <div class="cart-form-grid">
                  <label class="cart-field cart-field-full">
                    <span>Nombre y apellido</span>
                    <input type="text" name="fullName" autocomplete="name" minlength="5" maxlength={CHECKOUT_LIMITS.customer.fullName} pattern={checkoutConfig.patterns.fullName} title="Ingresá nombre y apellido reales." required />
                  </label>
                  <label class="cart-field">
                    <span>Email</span>
                    <input type="email" name="email" autocomplete="email" inputmode="email" maxlength={CHECKOUT_LIMITS.customer.email} required />
                  </label>
                  <label class="cart-field">
                    <span>Teléfono</span>
                    <input type="tel" name="phone" autocomplete="tel" inputmode="numeric" minlength="10" maxlength={CHECKOUT_LIMITS.customer.phone} pattern="\\d{10,13}" title="Ingresá un teléfono válido de Argentina, solo con números." required />
                  </label>
                </div>
              </section>

              <section class="cart-form-section">
                <div class="cart-form-head">
                  <p class="cart-form-eyebrow">Envío</p>
                  <h3>Dirección de entrega</h3>
                </div>
                <div class="cart-form-grid">
                  <label class="cart-field">
                    <span>Provincia</span>
                    <select name="province" autocomplete="address-level1" required>
                      <option value="">Seleccionar</option>
                      {ARGENTINA_PROVINCES.map((province) => (
                        <option value={province}>{province}</option>
                      ))}
                    </select>
                  </label>
                  <label class="cart-field">
                    <span>Ciudad</span>
                    <input type="text" name="city" autocomplete="address-level2" minlength="2" maxlength={CHECKOUT_LIMITS.shippingAddress.city} required />
                  </label>
                  <label class="cart-field">
                    <span>Código postal</span>
                    <input type="text" name="postalCode" autocomplete="postal-code" inputmode="text" minlength="4" maxlength={CHECKOUT_LIMITS.shippingAddress.postalCode} pattern={checkoutConfig.patterns.postalCode} title="Usá un código postal argentino válido, por ejemplo 1425 o C1425ABC." required />
                  </label>
                  <label class="cart-field">
                    <span>Calle</span>
                    <input type="text" name="street" autocomplete="address-line1" minlength="3" maxlength={CHECKOUT_LIMITS.shippingAddress.street} required />
                  </label>
                  <label class="cart-field">
                    <span>Altura</span>
                    <input type="text" name="streetNumber" inputmode="text" maxlength={CHECKOUT_LIMITS.shippingAddress.streetNumber} pattern={checkoutConfig.patterns.streetNumber} title="Ingresá una altura válida." required />
                  </label>
                  <label class="cart-field">
                    <span>Piso / depto</span>
                    <input type="text" name="apartment" autocomplete="address-line2" maxlength={CHECKOUT_LIMITS.shippingAddress.apartment} />
                  </label>
                  <label class="cart-field cart-field-full">
                    <span>Indicaciones para la entrega</span>
                    <textarea name="notes" rows="3" placeholder="Opcional" maxlength={CHECKOUT_LIMITS.shippingAddress.notes}></textarea>
                  </label>
                </div>
              </section>
            </form>

            <p class="muted cart-summary-status" data-cart-status></p>

            <div class="cart-summary-actions">
              <button class="btn" type="button" data-cart-pay data-analytics="cart-pay" data-analytics-kind="button">Pagar ahora con Mercado Pago</button>
              <div class="cart-wallet-shell" data-cart-wallet-shell hidden>
                <div class="cart-wallet-head">
                  <p class="cart-wallet-title">Continuar con el pago</p>
                  <p class="cart-wallet-copy">Si el botón tarda en cargar, podés abrir Mercado Pago directamente.</p>
                </div>
                <div class="cart-wallet" id="cart-wallet-brick"></div>
                <button class="btn btn-ghost cart-wallet-fallback" type="button" data-cart-open-checkout>
                  Abrir Mercado Pago
                </button>
              </div>
              <div class="cart-secondary-actions">
                <button class="btn btn-ghost" type="button" data-cart-wa data-analytics="cart-whatsapp" data-analytics-kind="button">Consultar por WhatsApp</button>
                <button class="btn btn-ghost" type="button" data-cart-clear data-analytics="cart-clear" data-analytics-kind="button">Vaciar selección</button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer />

  <script src="https://sdk.mercadopago.com/js/v2"></script>
  <script define:vars={{ whatsappNumber, mercadoPagoPublicKey, checkoutConfig }}>
    const CART_KEY = "fortunato_cart";
    const CHECKOUT_KEY = "fortunato_checkout";
    const list = document.querySelector("[data-cart-list]");
    const summaryEl = document.querySelector("[data-cart-summary]");
    const subtotalEl = document.querySelector("[data-cart-subtotal]");
    const totalEl = document.querySelector("[data-cart-total]");
    const shippingEl = document.querySelector("[data-cart-shipping]");
    const shippingCopyEl = document.querySelector("[data-cart-shipping-copy]");
    const checkoutForm = document.querySelector("[data-cart-checkout-form]");
    const clearBtn = document.querySelector("[data-cart-clear]");
    const payBtn = document.querySelector("[data-cart-pay]");
    const waBtn = document.querySelector("[data-cart-wa]");
    const openCheckoutBtn = document.querySelector("[data-cart-open-checkout]");
    const statusEl = document.querySelector("[data-cart-status]");
    const walletShell = document.querySelector("[data-cart-wallet-shell]");
    const payDefaultLabel = "Pagar ahora con Mercado Pago";
    const payLoadingLabel = "Preparando pago...";

    let state = {
      cart: [],
      quote: null,
      loading: false,
      paymentLoading: false,
      checkout: null
    };
    let walletBrickController = null;
    let quoteTimer = null;

    const defaultCheckout = () => ({
      customer: {
        fullName: "",
        email: "",
        phone: ""
      },
      shippingAddress: {
        province: "",
        city: "",
        postalCode: "",
        street: "",
        streetNumber: "",
        apartment: "",
        notes: ""
      }
    });

    const getCart = () => {
      try { return JSON.parse(localStorage.getItem(CART_KEY) || "[]"); } catch { return []; }
    };
    const setCart = (cart) => localStorage.setItem(CART_KEY, JSON.stringify(cart));
    const getStoredCheckout = () => {
      try {
        const parsed = JSON.parse(localStorage.getItem(CHECKOUT_KEY) || "null");
        return parsed && typeof parsed === "object" ? parsed : defaultCheckout();
      } catch {
        return defaultCheckout();
      }
    };
    const setStoredCheckout = (checkout) => {
      localStorage.setItem(CHECKOUT_KEY, JSON.stringify(checkout));
    };
    const safeImageSrc = (value) => {
      const src = String(value || "").trim();
      if (!src) return "/placeholder.svg";
      if (src.startsWith("/") || /^https?:\/\//i.test(src)) return src;
      return "/placeholder.svg";
    };
    const getMessage = (error, fallback) => {
      if (!error) return fallback;
      if (typeof error === "string") return error;
      if (error instanceof Error && error.message) return error.message;
      return fallback;
    };
    const cleanValue = (value, max = 120) =>
      String(value || "")
        .replace(/\r\n/g, "\n")
        .replace(/[\u0000-\u001F\u007F]/g, "")
        .replace(/\s+/g, " ")
        .trimStart()
        .slice(0, max);
    const sanitizeName = (value) =>
      cleanValue(value, checkoutConfig.limits.customer.fullName).replace(/[^A-Za-zÁÉÍÓÚÜÑáéíóúüñ' .-]/g, "");
    const sanitizeEmail = (value) =>
      cleanValue(value, checkoutConfig.limits.customer.email).replace(/\s+/g, "").toLowerCase();
    const sanitizePhone = (value) =>
      String(value || "").replace(/\D+/g, "").slice(0, checkoutConfig.limits.customer.phone);
    const sanitizeCity = (value) =>
      cleanValue(value, checkoutConfig.limits.shippingAddress.city).replace(/[^A-Za-zÁÉÍÓÚÜÑáéíóúüñ0-9' .-]/g, "");
    const sanitizePostalCode = (value) =>
      cleanValue(value, checkoutConfig.limits.shippingAddress.postalCode).replace(/[^A-Za-z0-9]/g, "").toUpperCase();
    const sanitizeStreet = (value) =>
      cleanValue(value, checkoutConfig.limits.shippingAddress.street).replace(/[^A-Za-zÁÉÍÓÚÜÑáéíóúüñ0-9' ./-]/g, "");
    const sanitizeStreetNumber = (value) =>
      cleanValue(value, checkoutConfig.limits.shippingAddress.streetNumber).replace(/[^A-Za-z0-9/-]/g, "");
    const sanitizeApartment = (value) =>
      cleanValue(value, checkoutConfig.limits.shippingAddress.apartment).replace(/[^A-Za-zÁÉÍÓÚÜÑáéíóúüñ0-9 ./-]/g, "");
    const sanitizeNotes = (value) =>
      cleanValue(value, checkoutConfig.limits.shippingAddress.notes);
    const isValidArgentinaPhone = (value) => {
      const digits = sanitizePhone(value);
      if (!digits) return false;
      if (digits.startsWith("54")) {
        return digits.length === 12 || digits.length === 13;
      }
      return digits.length === 10 || digits.length === 11;
    };
    const isValidPostalCode = (value) => /^(?:\d{4}|[A-Z]\d{4}[A-Z]{3})$/.test(String(value || "").trim());
    const isValidFullName = (value) =>
      /^[A-Za-zÁÉÍÓÚÜÑáéíóúüñ]+(?:[ '.-][A-Za-zÁÉÍÓÚÜÑáéíóúüñ]+)+$/.test(String(value || "").trim());
    const format = (amount, currency) =>
      typeof amount === "number" && !Number.isNaN(amount)
        ? `${currency} ${amount.toLocaleString("es-AR")}`
        : "Precio a confirmar";
    const normalizePhone = (value) => sanitizePhone(value);
    const sanitizeFieldValue = (field) => {
      if (!field?.name) return;
      const current = field.value || "";
      let next = current;
      switch (field.name) {
        case "fullName":
          next = sanitizeName(current);
          break;
        case "email":
          next = sanitizeEmail(current);
          break;
        case "phone":
          next = sanitizePhone(current);
          break;
        case "city":
          next = sanitizeCity(current);
          break;
        case "postalCode":
          next = sanitizePostalCode(current);
          break;
        case "street":
          next = sanitizeStreet(current);
          break;
        case "streetNumber":
          next = sanitizeStreetNumber(current);
          break;
        case "apartment":
          next = sanitizeApartment(current);
          break;
        case "notes":
          next = sanitizeNotes(current);
          break;
        default:
          next = cleanValue(current, 160);
      }
      if (next !== current) field.value = next;
    };
    const validateField = (field) => {
      if (!field?.name || typeof field.setCustomValidity !== "function") return true;
      sanitizeFieldValue(field);
      const value = String(field.value || "").trim();
      let message = "";
      if (field.name === "fullName" && value && !isValidFullName(value)) {
        message = "Ingresá nombre y apellido reales.";
      } else if (field.name === "email" && value && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value)) {
        message = "Ingresá un email válido.";
      } else if (field.name === "phone" && value && !isValidArgentinaPhone(value)) {
        message = "Ingresá un teléfono válido de Argentina, solo con números.";
      } else if (field.name === "city" && value && value.length < 2) {
        message = "Ingresá una ciudad válida.";
      } else if (field.name === "postalCode" && value && !isValidPostalCode(value)) {
        message = "Usá un código postal argentino válido.";
      } else if (field.name === "street" && value && value.length < 3) {
        message = "Ingresá una calle válida.";
      } else if (field.name === "streetNumber" && value && !/^[A-Za-z0-9/-]{1,10}$/.test(value)) {
        message = "Ingresá una altura válida.";
      }
      field.setCustomValidity(message);
      return !message;
    };
    const validateCheckoutForm = ({ report = false } = {}) => {
      if (!checkoutForm) return false;
      const fields = checkoutForm.querySelectorAll("input, select, textarea");
      fields.forEach((field) => validateField(field));
      return report ? checkoutForm.reportValidity() : checkoutForm.checkValidity();
    };
    const isCheckoutComplete = (checkout) => {
      const customer = checkout?.customer || {};
      const shippingAddress = checkout?.shippingAddress || {};
      return Boolean(
        isValidFullName(customer.fullName) &&
        /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(String(customer.email || "").trim()) &&
        isValidArgentinaPhone(customer.phone) &&
        String(shippingAddress.province || "").trim() &&
        String(shippingAddress.city || "").trim().length >= 2 &&
        isValidPostalCode(shippingAddress.postalCode) &&
        String(shippingAddress.street || "").trim().length >= 3 &&
        /^[A-Za-z0-9/-]{1,10}$/.test(String(shippingAddress.streetNumber || "").trim()) &&
        (!checkoutForm || validateCheckoutForm())
      );
    };

    const makeKey = (item) => `${item.id}__${item.color || ""}__${item.size || ""}`;
    const syncBadge = (cart) => {
      const badge = document.querySelector("[data-cart-count]");
      if (!badge) return;
      const count = (Array.isArray(cart) ? cart : []).reduce((sum, item) => sum + Number(item.qty || 0), 0);
      badge.textContent = count ? String(count) : "";
      badge.classList.toggle("is-visible", count > 0);
    };
    const persistCart = (cart) => {
      state.cart = Array.isArray(cart) ? cart : [];
      setCart(state.cart);
      syncBadge(state.cart);
    };
    const fillCheckoutForm = (checkout) => {
      if (!checkoutForm) return;
      checkoutForm.querySelector("[name=fullName]").value = checkout?.customer?.fullName || "";
      checkoutForm.querySelector("[name=email]").value = checkout?.customer?.email || "";
      checkoutForm.querySelector("[name=phone]").value = checkout?.customer?.phone || "";
      checkoutForm.querySelector("[name=province]").value = checkout?.shippingAddress?.province || "";
      checkoutForm.querySelector("[name=city]").value = checkout?.shippingAddress?.city || "";
      checkoutForm.querySelector("[name=postalCode]").value = checkout?.shippingAddress?.postalCode || "";
      checkoutForm.querySelector("[name=street]").value = checkout?.shippingAddress?.street || "";
      checkoutForm.querySelector("[name=streetNumber]").value = checkout?.shippingAddress?.streetNumber || "";
      checkoutForm.querySelector("[name=apartment]").value = checkout?.shippingAddress?.apartment || "";
      checkoutForm.querySelector("[name=notes]").value = checkout?.shippingAddress?.notes || "";
      validateCheckoutForm();
    };
    const readCheckoutForm = () => {
      if (!checkoutForm) return defaultCheckout();
      return {
        customer: {
          fullName: checkoutForm.querySelector("[name=fullName]")?.value || "",
          email: checkoutForm.querySelector("[name=email]")?.value || "",
          phone: checkoutForm.querySelector("[name=phone]")?.value || ""
        },
        shippingAddress: {
          province: checkoutForm.querySelector("[name=province]")?.value || "",
          city: checkoutForm.querySelector("[name=city]")?.value || "",
          postalCode: checkoutForm.querySelector("[name=postalCode]")?.value || "",
          street: checkoutForm.querySelector("[name=street]")?.value || "",
          streetNumber: checkoutForm.querySelector("[name=streetNumber]")?.value || "",
          apartment: checkoutForm.querySelector("[name=apartment]")?.value || "",
          notes: checkoutForm.querySelector("[name=notes]")?.value || ""
        }
      };
    };
    const persistCheckout = () => {
      const checkout = readCheckoutForm();
      setStoredCheckout(checkout);
      return checkout;
    };
    const resetCheckout = () => {
      state.checkout = null;
      if (walletBrickController?.unmount) {
        try { walletBrickController.unmount(); } catch {}
      }
      walletBrickController = null;
      const walletContainer = document.getElementById("cart-wallet-brick");
      if (walletContainer) walletContainer.replaceChildren();
      if (walletShell) walletShell.hidden = true;
      if (payBtn) payBtn.hidden = false;
    };

    const setStatus = (text, type = "") => {
      if (!statusEl) return;
      statusEl.textContent = text || "";
      statusEl.dataset.type = type;
    };
    const createNode = (tag, className, text) => {
      const node = document.createElement(tag);
      if (className) node.className = className;
      if (typeof text === "string") node.textContent = text;
      return node;
    };
    const renderEmptyState = () => {
      const card = createNode("div", "cart-empty");
      card.append(createNode("p", "cart-empty-eyebrow", "Carrito vacío"));
      card.append(createNode("h3", "cart-empty-title", "Todavía no agregaste prendas."));
      card.append(createNode("p", "muted", "Explorá la cápsula y armá una selección antes de pagar."));

      const actions = createNode("div", "cart-empty-actions");
      const shopLink = createNode("a", "btn", "Explorar colección");
      shopLink.href = "/capsula";
      const waLink = createNode("a", "btn btn-ghost", "Consultar por WhatsApp");
      waLink.href = `https://wa.me/${whatsappNumber}`;
      actions.append(shopLink, waLink);
      card.append(actions);
      list.replaceChildren(card);
    };
    const createCartItem = (item) => {
      const article = createNode("article", "cart-item");
      article.dataset.key = makeKey(item);

      const image = createNode("img");
      image.src = safeImageSrc(item.image);
      image.alt = String(item.name || "Producto Fortunato");
      article.append(image);

      const main = createNode("div", "cart-item-main");
      const top = createNode("div", "cart-item-top");
      const name = createNode("strong", "cart-item-name", String(item.name || "Producto Fortunato"));
      const remove = createNode("button", "cart-remove", "×");
      remove.type = "button";
      remove.setAttribute("data-cart-remove", "");
      remove.setAttribute("aria-label", "Eliminar");
      top.append(name, remove);
      main.append(top);

      const meta = createNode("div", "cart-item-meta");
      if (item.color) {
        meta.append(createNode("span", "cart-item-pill", `Color ${String(item.color)}`));
      }
      if (item.size) {
        meta.append(createNode("span", "cart-item-pill", `Talle ${String(item.size)}`));
      }
      if (meta.childNodes.length) {
        main.append(meta);
      }
      if (item.stockLabel) {
        main.append(createNode("span", item.isLowStock ? "cart-stock cart-stock-low" : "cart-stock", String(item.stockLabel)));
      }

      const bottom = createNode("div", "cart-item-bottom");
      const qtyWrap = createNode("div", "cart-qty");
      qtyWrap.setAttribute("aria-label", "Cantidad");
      const dec = createNode("button", "cart-qty-btn", "−");
      dec.type = "button";
      dec.setAttribute("data-cart-dec", "");
      dec.setAttribute("aria-label", "Disminuir");
      const qtyValue = createNode("span", "cart-qty-value", String(item.qty || 1));
      qtyValue.setAttribute("aria-live", "polite");
      const inc = createNode("button", "cart-qty-btn", "+");
      inc.type = "button";
      inc.setAttribute("data-cart-inc", "");
      inc.setAttribute("aria-label", "Aumentar");
      qtyWrap.append(dec, qtyValue, inc);

      const priceBlock = createNode("div", "cart-price-block");
      priceBlock.append(createNode("span", "cart-price-label", "Total"));
      priceBlock.append(createNode("strong", "cart-line-total", format(Number(item.lineTotal || 0), item.currency || "ARS")));
      if (Number(item.qty || 0) > 1) {
        priceBlock.append(
          createNode("span", "muted cart-each", `(c/u ${format(Number(item.unitPrice || 0), item.currency || "ARS")})`)
        );
      }

      bottom.append(qtyWrap, priceBlock);
      main.append(bottom);
      article.append(main);
      return article;
    };
    const renderTotals = (quote) => {
      const subtotal = Number(quote?.subtotal || 0);
      const total = Number(quote?.total || subtotal);
      subtotalEl.textContent = format(subtotal, quote?.currency || "ARS");
      shippingEl.textContent = "A confirmar";
      totalEl.textContent = format(total, quote?.currency || "ARS");

      if (!isCheckoutComplete(readCheckoutForm())) {
        shippingCopyEl.textContent = "Completá tus datos de entrega para registrar el pedido correctamente.";
        return;
      }
      const address = quote?.checkout?.shippingAddress || {};
      const destination = [address.city, address.province].filter(Boolean).join(", ");
      shippingCopyEl.textContent = destination
        ? `Usaremos la dirección de ${destination} para confirmarte el costo de envío después de la compra.`
        : "Después de la compra te confirmamos el costo de envío según tu dirección.";
    };
    const getCheckoutIssueMessage = (quote) => {
      const checkoutIssues = Array.isArray(quote?.checkoutIssues) ? quote.checkoutIssues : [];
      if (checkoutIssues.length) return checkoutIssues[0];
      const issues = Array.isArray(quote?.issues) ? quote.issues : [];
      if (issues.length) {
        return issues
          .map((issue) => issue?.message)
          .filter(Boolean)
          .slice(0, 1)
          .join(" ");
      }
      return "";
    };
    const syncCheckoutStatus = (quote, { silent = false } = {}) => {
      const issueMessage = getCheckoutIssueMessage(quote);
      if (issueMessage) {
        setStatus(issueMessage, "error");
        return;
      }
      if (!silent) setStatus("");
    };

    const render = () => {
      const cart = Array.isArray(state.cart) ? state.cart : [];
      if (!cart.length) {
        resetCheckout();
        renderEmptyState();
        subtotalEl.textContent = "ARS 0";
        shippingEl.textContent = "A confirmar";
        totalEl.textContent = "ARS 0";
        shippingCopyEl.textContent = "Completá tus datos de entrega. El costo de envío se confirma después de la compra.";
        if (summaryEl) summaryEl.hidden = true;
        if (payBtn) {
          payBtn.disabled = true;
          payBtn.textContent = payDefaultLabel;
        }
        if (waBtn) waBtn.disabled = true;
        if (openCheckoutBtn) openCheckoutBtn.disabled = true;
        setStatus("");
        return;
      }

      if (summaryEl) summaryEl.hidden = false;
      if (state.loading) {
        list.replaceChildren(createNode("p", "muted", "Actualizando tu carrito..."));
        if (payBtn) payBtn.disabled = true;
        if (waBtn) waBtn.disabled = true;
        return;
      }

      const quoteItems = Array.isArray(state.quote?.items) ? state.quote.items : [];
      if (!quoteItems.length) {
        resetCheckout();
        list.replaceChildren(createNode("p", "muted", "No pudimos validar tu selección. Probá de nuevo en unos segundos."));
        subtotalEl.textContent = "ARS —";
        shippingEl.textContent = "A confirmar";
        totalEl.textContent = "ARS —";
        shippingCopyEl.textContent = "Completá tus datos de entrega. El costo de envío se confirma después de la compra.";
        if (payBtn) {
          payBtn.disabled = true;
          payBtn.textContent = payDefaultLabel;
        }
        if (waBtn) waBtn.disabled = true;
        if (openCheckoutBtn) openCheckoutBtn.disabled = true;
        return;
      }

      const readyToPay = Boolean(
        isCheckoutComplete(readCheckoutForm()) &&
        (!Array.isArray(state.quote?.issues) || !state.quote.issues.length) &&
        (!Array.isArray(state.quote?.checkoutIssues) || !state.quote.checkoutIssues.length)
      );

      if (payBtn) {
        payBtn.disabled = state.paymentLoading || !readyToPay;
        payBtn.hidden = Boolean(state.checkout);
        payBtn.textContent = state.paymentLoading ? payLoadingLabel : payDefaultLabel;
      }
      if (waBtn) waBtn.disabled = false;
      if (openCheckoutBtn) openCheckoutBtn.disabled = !state.checkout?.checkoutUrl;
      if (walletShell) walletShell.hidden = !state.checkout;

      const rows = quoteItems.map((item) => createCartItem(item));
      list.replaceChildren(...rows);
      renderTotals(state.quote);
    };

    const buildWhatsappText = (quote, checkout) => {
      const lines = (quote?.items || []).map((item) => {
        const qty = Number(item.qty || 0);
        const parts = [
          `- ${item.name} x${qty}`,
          item.color ? `Color: ${item.color}` : "",
          item.size ? `Talle: ${item.size}` : "",
          `— ${format(Number(item.lineTotal || 0), item.currency || "ARS")}`
        ].filter(Boolean);
        return parts.join(" · ");
      });

      const address = checkout?.shippingAddress || {};
      const addressLine = [
        address.street ? `${address.street} ${address.streetNumber || ""}`.trim() : "",
        address.city,
        address.province,
        address.postalCode
      ].filter(Boolean).join(", ");

      return [
        "Hola! Quiero confirmar este pedido de Fortunato:",
        "",
        ...lines,
        "",
        `Productos: ${format(Number(quote?.subtotal || 0), quote?.currency || "ARS")}`,
        "Envío: A confirmar después de la compra",
        `Total: ${format(Number(quote?.total || quote?.subtotal || 0), quote?.currency || "ARS")}`,
        addressLine ? `Entrega: ${addressLine}` : "",
        "",
        "Quiero coordinar la entrega y confirmar los datos de la compra."
      ].filter(Boolean).join("\n");
    };

    const requestQuote = async (cart, checkout) => {
      const response = await fetch("/api/cart/quote", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ cart, checkout })
      });
      if (!response.ok) {
        throw new Error("No pudimos validar el carrito.");
      }
      return response.json();
    };

    const syncQuote = async ({ silent = false } = {}) => {
      const cart = getCart();
      const checkout = persistCheckout();
      persistCart(cart);
      resetCheckout();
      if (!cart.length) {
        state.quote = null;
        state.loading = false;
        render();
        return null;
      }

      state.loading = true;
      render();
      try {
        const quote = await requestQuote(cart, checkout);
        state.quote = quote;
        persistCart(Array.isArray(quote?.cart) ? quote.cart : []);
        state.loading = false;
        render();
        syncCheckoutStatus(quote, { silent });
        return quote;
      } catch (error) {
        state.loading = false;
        state.quote = null;
        render();
        setStatus(getMessage(error, "No pudimos validar el carrito."), "error");
        return null;
      }
    };

    const scheduleQuoteSync = () => {
      if (quoteTimer) window.clearTimeout(quoteTimer);
      quoteTimer = window.setTimeout(() => {
        syncQuote({ silent: true });
      }, 280);
    };

    const openCheckoutFallback = (checkoutUrl) => {
      if (!checkoutUrl) return;
      setStatus("Abriendo Mercado Pago...", "pending");
      window.location.assign(checkoutUrl);
    };

    const mountWalletBrick = async ({ preferenceId, checkoutUrl }) => {
      const MercadoPagoCtor = window.MercadoPago;
      const walletContainer = document.getElementById("cart-wallet-brick");
      if (!walletContainer || !mercadoPagoPublicKey || typeof MercadoPagoCtor !== "function") {
        openCheckoutFallback(checkoutUrl);
        return;
      }

      resetCheckout();
      state.checkout = { preferenceId, checkoutUrl };
      if (payBtn) payBtn.hidden = true;
      if (walletShell) walletShell.hidden = false;

      try {
        const mercadoPago = new MercadoPagoCtor(mercadoPagoPublicKey, { locale: "es" });
        const bricksBuilder = mercadoPago.bricks();
        walletBrickController = await bricksBuilder.create("wallet", "cart-wallet-brick", {
          initialization: {
            preferenceId,
            redirectMode: "blank"
          },
          callbacks: {
            onReady: () => {
              setStatus("Mercado Pago listo para continuar.", "pending");
            },
            onError: () => {
              setStatus("No pudimos cargar el botón. Abrimos Mercado Pago directamente.", "error");
              resetCheckout();
              openCheckoutFallback(checkoutUrl);
            }
          }
        });
      } catch (error) {
        resetCheckout();
        openCheckoutFallback(checkoutUrl);
        throw error;
      }
    };

    list?.addEventListener("click", (event) => {
      const row = event.target.closest("[data-key]");
      if (!row) return;
      const key = row.dataset.key;
      const cart = getCart();
      const index = cart.findIndex((item) => makeKey(item) === key);
      if (index === -1) return;

      if (event.target.closest("[data-cart-remove]")) {
        cart.splice(index, 1);
        persistCart(cart);
        syncQuote({ silent: true });
        return;
      }

      if (event.target.closest("[data-cart-inc]")) {
        cart[index].qty = Number(cart[index].qty || 0) + 1;
        persistCart(cart);
        syncQuote({ silent: true });
        return;
      }

      if (event.target.closest("[data-cart-dec]")) {
        const next = Number(cart[index].qty || 0) - 1;
        if (next <= 0) cart.splice(index, 1);
        else cart[index].qty = next;
        persistCart(cart);
        syncQuote({ silent: true });
      }
    });

    checkoutForm?.addEventListener("input", (event) => {
      const field = event.target;
      if (field && checkoutForm.contains(field)) validateField(field);
      const checkout = persistCheckout();
      if (!isCheckoutComplete(checkout)) {
        const message = field?.validationMessage || "Completá los datos de contacto y envío para continuar.";
        setStatus(message, "error");
      } else if (statusEl?.dataset.type === "error") {
        setStatus("");
      }
      scheduleQuoteSync();
    });
    checkoutForm?.addEventListener("change", (event) => {
      const field = event.target;
      if (field && checkoutForm.contains(field)) validateField(field);
      const checkout = persistCheckout();
      if (!isCheckoutComplete(checkout)) {
        const message = field?.validationMessage || "Completá los datos de contacto y envío para continuar.";
        setStatus(message, "error");
      }
      scheduleQuoteSync();
    });

    clearBtn?.addEventListener("click", () => {
      const cart = getCart();
      if (!cart.length) return;
      if (!confirm("¿Vaciar selección?")) return;
      persistCart([]);
      state.quote = null;
      resetCheckout();
      render();
    });

    payBtn?.addEventListener("click", async () => {
      const checkout = persistCheckout();
      if (!validateCheckoutForm({ report: true })) {
        setStatus("Completá tus datos de contacto y envío para continuar.", "error");
        return;
      }

      const quote = await syncQuote({ silent: true });
      if (!quote || !Array.isArray(quote.items) || !quote.items.length) return;
      if (Array.isArray(quote.issues) && quote.issues.length) {
        setStatus("Actualizamos el carrito según el stock disponible. Revisalo antes de pagar.", "error");
        return;
      }
      if (Array.isArray(quote.checkoutIssues) && quote.checkoutIssues.length) {
        setStatus(quote.checkoutIssues[0] || "Revisá los datos de contacto y envío.", "error");
        return;
      }
      if (!isCheckoutComplete(checkout)) {
        setStatus("Completá tus datos antes de continuar con el pago.", "error");
        return;
      }

      state.paymentLoading = true;
      render();
      setStatus("Preparando Mercado Pago...", "pending");
      try {
        const response = await fetch("/api/mercadopago/preference", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ cart: state.cart, checkout })
        });
        const payload = await response.json().catch(() => null);
        if (response.status === 409 && payload?.quote) {
          state.quote = payload.quote;
          persistCart(Array.isArray(payload.quote.cart) ? payload.quote.cart : []);
          render();
          setStatus(payload?.error === "Checkout requires review"
            ? (payload.quote?.checkoutIssues?.[0] || "Revisá los datos de entrega antes de continuar.")
            : "El stock cambió mientras preparábamos el pago. Ya actualizamos tu carrito.", "error");
          return;
        }
        if (!response.ok || !payload?.checkoutUrl || !payload?.preferenceId) {
          throw new Error(payload?.error || "No pudimos abrir Mercado Pago.");
        }
        await mountWalletBrick(payload);
      } catch (error) {
        setStatus(getMessage(error, "No pudimos abrir Mercado Pago."), "error");
      } finally {
        state.paymentLoading = false;
        render();
      }
    });

    waBtn?.addEventListener("click", () => {
      if (!state.quote?.items?.length) return;
      const text = buildWhatsappText(state.quote, persistCheckout());
      setStatus("Abriendo WhatsApp...", "pending");
      window.location.href = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(text)}`;
    });

    openCheckoutBtn?.addEventListener("click", () => {
      if (!state.checkout?.checkoutUrl) return;
      setStatus("Abriendo Mercado Pago...", "pending");
      openCheckoutFallback(state.checkout.checkoutUrl);
    });

    persistCart(getCart());
    fillCheckoutForm(getStoredCheckout());
    syncQuote();
  </script>
</Base>
