---
import Base from "../layouts/Base.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import ProductCard from "../components/ProductCard.astro";
import { getAllProducts, isPublicProduct } from "../lib/products";

export const prerender = false;

const products = (await getAllProducts()).filter(isPublicProduct);

const homeOrder = [
  "camisa-riviera",
  "chomba-sprezzata",
  "remera-doppio-collo",
  "pantalon-sastrero",
  "bermuda-rilassata",
  "bermuda-sastrera",
  "sandalias-crudem"
];
const orderIndex = new Map(homeOrder.map((id, index) => [id, index]));
const orderedProducts = [...products].sort((a, b) => {
  const aIndex = orderIndex.has(a.id) ? orderIndex.get(a.id) : Number.MAX_SAFE_INTEGER;
  const bIndex = orderIndex.has(b.id) ? orderIndex.get(b.id) : Number.MAX_SAFE_INTEGER;
  if (aIndex !== bIndex) return aIndex - bIndex;
  return String(a.name || "").localeCompare(String(b.name || ""), "es");
});

const newInProducts = orderedProducts
  .filter((p) => p.badge === "Nuevo")
  .map((p) => ({ ...p, cardVariant: "standard" }));

// Excluir productos de NEW IN del grid principal para no mostrarlos dos veces
const newInIds = new Set(newInProducts.map((p) => p.id));
const gridProducts = orderedProducts.filter((p) => !newInIds.has(p.id));

const filters = [
  { id: "todo",    label: "Todo",    count: gridProducts.length },
  { id: "top",     label: "Tops",    count: gridProducts.filter((p) => p.category === "top").length },
  { id: "bottom",  label: "Bottoms", count: gridProducts.filter((p) => p.category === "bottom").length },
  { id: "calzado", label: "Calzado", count: gridProducts.filter((p) => p.category === "calzado").length },
];
---

<Base title="Fortunato | Cápsula" description="Explorá la cápsula completa de Fortunato con stock y precios validados desde backend.">
  <Header current="capsula" />

  <main>
    <section id="capsula" class="section section-capsule">
      <div class="container">

        {/* ── HEAD ─────────────────────────────── */}
        <div class="section-head capsule-head">
          <div class="capsule-head__copy">
            <p class="eyebrow">Cápsula</p>
            <h2>Piezas pensadas para combinar entre sí.</h2>
            <p class="muted">Elegí color y talle en cada prenda. El carrito revalida disponibilidad antes del pago.</p>
          </div>
        </div>

        {/* ── NEW IN ────────────────────────────── */}
        {newInProducts.length > 0 && (
          <div class="new-in">
            <div class="new-in__divider">
              <span class="new-in__tag">New in</span>
            </div>
            <div class="new-in__grid">
              {newInProducts.map((product) => (
                <ProductCard product={product} />
              ))}
            </div>
          </div>
        )}

        {/* ── FILTROS ──────────────────────────── */}
        <div class="capsule-filters-row">
          <div class="capsule-filters" role="group" aria-label="Filtrar por categoría">
            {filters.map((f) => (
              <button
                type="button"
                class:list={["capsule-filter", f.id === "todo" && "is-active"]}
                data-filter={f.id}
                aria-pressed={f.id === "todo" ? "true" : "false"}
              >
                {f.label}
                <span class="capsule-filter__count">{f.count}</span>
              </button>
            ))}
          </div>
        </div>

        {/* ── GRILLA ───────────────────────────── */}
        <p class="capsule-empty" hidden aria-live="polite">
          No hay prendas en esta categoría.
        </p>

        <div class="capsule-grid" id="capsule-grid">
          {gridProducts.map((product) => (
            <ProductCard product={product} />
          ))}
        </div>

      </div>
    </section>
  </main>

  <Footer />
</Base>

<script>
  const buttons = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-filter]"));
  const cards   = Array.from(document.querySelectorAll<HTMLElement>("#capsule-grid [data-category]"));
  const empty   = document.querySelector<HTMLElement>(".capsule-empty");

  const applyFilter = (filterId: string) => {
    let visible = 0;
    cards.forEach((card) => {
      const show = filterId === "todo" || card.dataset.category === filterId;
      card.style.display = show ? "" : "none";
      if (show) visible++;
    });
    buttons.forEach((btn) => {
      const active = btn.dataset.filter === filterId;
      btn.classList.toggle("is-active", active);
      btn.setAttribute("aria-pressed", active ? "true" : "false");
    });
    if (empty) empty.hidden = visible > 0;
  };

  buttons.forEach((btn) => {
    btn.addEventListener("click", () => applyFilter(btn.dataset.filter ?? "todo"));
  });
</script>

<style>
  /* ── HEAD ───────────────────────────────── */
  .capsule-head {
    margin-bottom: 2rem;
  }

  /* ── NEW IN ─────────────────────────────── */
  .new-in__divider {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }
  .new-in__divider::before,
  .new-in__divider::after {
    content: "";
    flex: 1;
    height: 1px;
    background: rgba(24,74,69,0.12);
  }

  .new-in__tag {
    font-family: "Cinzel","Cormorant Garamond",serif;
    font-size: 0.72rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--green);
    white-space: nowrap;
    flex: 0 0 auto;
  }

  /* New-in: flex con ancho fijo por card — se escala con cuántos productos haya */
  .new-in {
    margin-bottom: 2.5rem;
  }
  @media (min-width: 760px) {
    .new-in {
      max-width: 580px; /* ~2 cards × 260px + gap */
    }
  }
  .new-in__grid {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  /* Mobile: full-width. Desktop: ancho fijo tipo spotlight */
  .new-in__grid :global(.product-card) {
    flex: 0 0 100%;
    grid-column: unset;
  }
  @media (min-width: 540px) {
    .new-in__grid :global(.product-card) {
      flex: 0 0 260px;
    }
  }
  /* Fuerza layout single-column dentro de NEW IN (cancela el double layout) */
  .new-in__grid :global(.product-card.is-double) {
    grid-template-columns: 1fr;
    grid-template-rows: auto;
  }
  .new-in__grid :global(.product-card.is-double .product-media) {
    aspect-ratio: 4 / 5;
    height: auto;
  }

  /* Double card en grid principal → layout estándar en mobile */
  @media (max-width: 759px) {
    #capsule-grid :global(.product-card.is-double) {
      grid-column: 1 / -1;
      grid-template-columns: 1fr;
    }
    #capsule-grid :global(.product-card.is-double .product-media) {
      aspect-ratio: 4 / 5;
      height: auto;
    }
  }

  /* ── FILTROS ────────────────────────────── */
  .capsule-filters-row {
    padding: 1rem 0 1.25rem;
    border-top: 1px solid rgba(24,74,69,0.08);
    margin-bottom: 0.25rem;
  }

  .capsule-filters {
    display: flex;
    gap: 0.5rem;
    overflow-x: auto;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }
  .capsule-filters::-webkit-scrollbar { display: none; }

  .capsule-filter {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.55rem 1.15rem;
    border-radius: 999px;
    border: 1px solid rgba(24,74,69,0.14);
    background: rgba(255,255,255,0.72);
    color: var(--slate);
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.15s ease, border-color 0.15s ease, color 0.15s ease, box-shadow 0.15s ease;
    min-height: 44px;
    box-shadow: 0 2px 8px rgba(24,74,69,0.04);
  }

  .capsule-filter.is-active {
    background: var(--green);
    color: var(--beige);
    border-color: var(--green);
    box-shadow: 0 4px 16px rgba(24,74,69,0.18);
  }

  .capsule-filter__count {
    font-size: 0.72rem;
    opacity: 0.55;
    font-weight: 400;
  }
  .capsule-filter.is-active .capsule-filter__count {
    opacity: 0.65;
  }

  @media (hover: hover) and (pointer: fine) {
    .capsule-filter:not(.is-active):hover {
      background: rgba(24,74,69,0.06);
      border-color: rgba(24,74,69,0.24);
      box-shadow: 0 2px 12px rgba(24,74,69,0.08);
    }
  }

  /* ── EMPTY STATE ────────────────────────── */
  .capsule-empty {
    padding: 3rem 0;
    text-align: center;
    color: var(--warm);
    font-size: 1rem;
  }
</style>
