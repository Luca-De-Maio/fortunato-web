---
import { Image } from "astro:assets";
import logoMark from "../assets/logo-mark.png";
import logoWordmark from "../assets/logo-wordmark.png";
import SearchOverlay from "./SearchOverlay.astro";
const { current = "" } = Astro.props;
---
<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand" aria-label="Fortunato">
      <span class="brand-mark-box" aria-hidden="true">
        <Image
          src={logoMark}
          alt=""
          class="brand-mark-image"
          width={1869}
          height={1869}
          priority
          decoding="async"
        />
      </span>
      <span class="brand-wordmark-box" aria-hidden="true">
        <Image
          src={logoWordmark}
          alt=""
          class="brand-wordmark-image"
          width={3906}
          height={374}
          priority
          decoding="async"
        />
      </span>
      <span class="brand-text">Fortunato</span>
    </a>
    <!-- Search button: always visible, positioned independently from the nav -->
    <button
      type="button"
      class="header-search-btn"
      data-search-open
      aria-label="Buscar productos"
      title="Buscar (⌘K)"
    >
      <svg width="17" height="17" viewBox="0 0 17 17" fill="none" aria-hidden="true">
        <circle cx="7" cy="7" r="5.2" stroke="currentColor" stroke-width="1.5"/>
        <path d="M11 11L15.5 15.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>

    <nav class="nav">
      <a href="/capsula" class:list={["nav-link", "nav-link-primary", current === "capsula" && "is-active"]}>Cápsula</a>
      <a href="/#conjuntos" class:list={["nav-link", "nav-link-primary", current === "conjuntos" && "is-active"]}>Conjuntos</a>
      <a href="/nuestra-historia" class:list={["nav-link", "nav-link-primary", current === "historia" && "is-active"]}>Historia</a>
      <a href="/#faq" class:list={["nav-link", "nav-link-faq", current === "faq" && "is-active"]}>FAQ</a>
      <a href="/cart" class="nav-link cart-link">
        Carrito
        <span class="cart-badge" data-cart-count></span>
      </a>
    </nav>
  </div>
</header>

<SearchOverlay />
