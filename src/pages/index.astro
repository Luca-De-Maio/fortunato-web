---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ComboCarousel from "../components/ComboCarousel.astro";
import EditorialShowcase from "../components/EditorialShowcase.astro";
import FAQ from "../components/FAQ.astro";
import HeroCarousel from "../components/HeroCarousel.astro";
import MarqueeBand from "../components/MarqueeBand.astro";
import { quoteCart } from "../lib/commerce";
import { getAllProducts } from "../lib/products";
import { getAllCombinations } from "../lib/combinations";

export const prerender = false;

const products = await getAllProducts();
const getVariantCount = (category) =>
  products
    .filter((product) => String(product.category || "").toLowerCase() === category)
    .reduce((sum, product) => sum + Math.max(Array.isArray(product.colors) ? product.colors.length : 0, 1), 0);
const validOutfitCount = getVariantCount("top") * getVariantCount("bottom");
const validOutfitLabel = new Intl.NumberFormat("es-AR").format(validOutfitCount);
const promoBandItems = [
  "Envíos gratis desde $129.000",
  "Envíos a todo el país con seguimiento",
  "Cambios dentro de los 10 días",
  "Mercado Pago integrado"
];
const capsuleBandItems = [
  `${validOutfitLabel} combinaciones posibles`,
  "Prendas pensadas para combinarse entre sí",
  "Menos piezas, más formas de usar la cápsula",
  "Looks sobrios, simples y bien resueltos"
];
const serviceBandItems = [
  "Atención directa por WhatsApp",
  "Entrega estimada entre 48 y 96 hs según zona",
  "Cambios dentro de los 10 días",
  "Mercado Pago integrado"
];
const combinations = await Promise.all(
  (await getAllCombinations()).map(async (combo) => {
    const comboQuote = await quoteCart([{ id: `combo-${combo.id}`, qty: 1 }]);
    const availableQty = Number(comboQuote.items?.[0]?.availableQty || 0);
    return {
      ...combo,
      availableQty,
      inStock: availableQty > 0
    };
  })
);
const slides = [
  {
    eyebrow: "",
    title: "Vestite bien, sin esfuerzo.",
    copy: "",
    image: "/images/hero/posible-hero-chomba-eze.JPG",
    imageAlt: "Modelo con chomba mostaza posando en interior claro",
    primaryHref: "/capsula",
    primaryLabel: "Explorar cápsula"
  },
  {
    eyebrow: "",
    title: "Vestite bien, sin esfuerzo.",
    copy: "",
    image: "/images/hero/fotoEZEsimilar.JPG",
    imageAlt: "Modelo con remera negra y bermuda camel en interior claro",
    primaryHref: "/capsula",
    primaryLabel: "Explorar cápsula"
  }
];
---

<Base title="Fortunato | Moda masculina premium" description="Cápsula limitada de prendas premium inspiradas en la herencia italo-argentina.">
  <Header />
  <main>
    <HeroCarousel slides={slides} />
    <MarqueeBand items={promoBandItems} analyticsSection="promo-band" />

    <section id="direccion" class="section home-overview" data-analytics-section="direccion">
      <div class="container home-overview-grid">
        <div class="home-overview-copy">
          <h2>Pocas prendas. {validOutfitLabel} looks posibles.</h2>
          <p class="muted">
            Cada pieza fue pensada para combinarse con las demás y resolver outfits distintos sin sumar ruido.
          </p>
        </div>

        <div class="home-route-grid">
          <a class="home-route-card" href="/capsula">
            <span class="home-route-label">Cápsula</span>
            <strong>Ver toda la cápsula</strong>
            <p>Entrá por prenda y elegí color y talle en pocos pasos.</p>
          </a>
          <a class="home-route-card is-contrast" href="#conjuntos">
            <span class="home-route-label">Conjuntos</span>
            <strong>Empezar por un look armado</strong>
            <p>Resolvé más rápido desde una combinación ya curada.</p>
          </a>
        </div>
      </div>
    </section>

    <MarqueeBand items={capsuleBandItems} tone="contrast" analyticsSection="capsule-band" />

    <section id="conjuntos" class="section home-section-alt">
      <div class="container">
        <div class="section-head">
          <p class="eyebrow">Conjuntos</p>
          <h2>Looks armados para decidir más rápido.</h2>
          <p class="muted">Cada conjunto reúne prendas que ya funcionan entre sí para que resuelvas el outfit con menos pasos.</p>
        </div>
        <ComboCarousel combinations={combinations} />
      </div>
    </section>

    <EditorialShowcase />

    <MarqueeBand items={serviceBandItems} analyticsSection="service-band" />

    <FAQ />
  </main>

  <Footer />
</Base>
