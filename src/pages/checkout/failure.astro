---
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
---

<Base title="Fortunato | Pago rechazado" description="No se pudo completar el pago.">
  <Header />

  <main class="checkout-page">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Estado del pago</p>
        <h2>No se pudo completar el pago</h2>
        <p class="muted">Tu pago fue rechazado o cancelado. Podés intentar de nuevo o escribirnos por WhatsApp.</p>
      </div>

      <div style="margin-top: 1.4rem; display: grid; gap: 0.8rem;">
        <a class="btn" href="/cart">Volver al carrito</a>
        <a class="btn btn-ghost" href="https://wa.me/5491158204344">Comprar por WhatsApp</a>
      </div>
    </div>
  </main>

  <Footer />
</Base>
