---
import { Image } from "astro:assets";
import logo from "../assets/logo.png";
const { current = "" } = Astro.props;
---
<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand" aria-label="Fortunato">
      <span class="brand-logo-box">
        <Image
          src={logo}
          alt="Fortunato"
          class="brand-logo"
          width={320}
          height={202}
          priority
          decoding="async"
        />
      </span>
      <span class="brand-text">Fortunato</span>
    </a>
    <nav class="nav">
      <a href="/#capsula" class:list={["nav-link", "nav-link-primary", current === "capsula" && "is-active"]}>Cápsula</a>
      <a href="/#categorias" class:list={["nav-link", "nav-link-secondary", current === "categorias" && "is-active"]}>Categorías</a>
      <a href="/#faq" class:list={["nav-link", "nav-link-primary", current === "faq" && "is-active"]}>FAQ</a>
      <a href="/cart" class="nav-link cart-link">
        Carrito
        <span class="cart-badge" data-cart-count></span>
      </a>
    </nav>
  </div>
</header>
