---
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
---

<Base title="Fortunato | Pago pendiente" description="Tu pago está pendiente.">
  <Header />

  <main class="checkout-page">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Mercado Pago</p>
        <h2>Pago pendiente</h2>
        <p class="muted">Tu pago está en proceso. Si se acredita, te avisaremos y seguimos con el pedido.</p>
      </div>

      <div style="margin-top: 1.4rem; display: grid; gap: 0.8rem;">
        <a class="btn" href="/cart">Volver al carrito</a>
        <a class="btn btn-ghost" href="https://wa.me/5491158204344">Consultar por WhatsApp</a>
      </div>
    </div>
  </main>

  <Footer />
</Base>
