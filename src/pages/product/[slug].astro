---
import { Image } from "astro:assets";
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { getProductBySlug } from "../../lib/products";

export const prerender = false;

const { slug } = Astro.params;
const product = await getProductBySlug(slug);
if (!product) {
  throw new Response(null, { status: 404, statusText: "Not found" });
}
const normalizeImageKey = (value = "") => String(value).trim().toLowerCase();
const isGridVariant = (value = "") => /-grid\.[a-z0-9]+$/i.test(String(value).trim());
const dedupedImages = (() => {
  const seen = new Set();
  const out = [];
  const list = Array.isArray(product.images) ? product.images : [];
  for (const src of list) {
    const key = normalizeImageKey(src);
    if (!key || seen.has(key) || isGridVariant(key)) continue;
    seen.add(key);
    out.push(src);
  }
  return out;
})();
const images = (() => {
  if (!dedupedImages.length) return ["/placeholder.svg"];
  const hero = dedupedImages.find((src) => normalizeImageKey(src).includes("-hero."));
  if (!hero) return dedupedImages;
  return [hero, ...dedupedImages.filter((src) => src !== hero)];
})();
const slugKey = String(product.slug || "").trim().toLowerCase();
const preferredThumbOrderBySlug = {
  "camisa-riviera": ["camisa-riviera-hero", "look-negro", "look-tabaco"]
};
const preferredMainImageBySlug = {
  "camisa-riviera": "look-tabaco"
};
const reorderImages = (list = [], preferredPatterns = []) => {
  const pending = [...list];
  const ordered = [];
  preferredPatterns.forEach((pattern) => {
    const nextIndex = pending.findIndex((src) => normalizeImageKey(src).includes(pattern));
    if (nextIndex === -1) return;
    ordered.push(pending[nextIndex]);
    pending.splice(nextIndex, 1);
  });
  return [...ordered, ...pending];
};
const galleryImages = reorderImages(images, preferredThumbOrderBySlug[slugKey] || []);
const initialMainImage = (() => {
  const preferredPattern = preferredMainImageBySlug[slugKey];
  if (!preferredPattern) return galleryImages[0] || "/placeholder.svg";
  return galleryImages.find((src) => normalizeImageKey(src).includes(preferredPattern)) || galleryImages[0] || "/placeholder.svg";
})();
const isEditorialHero = slugKey === "camisa-riviera";
const hasSingleImage = galleryImages.length === 1;
const useContainedHero = hasSingleImage || isEditorialHero;
const formatPrice = (value) =>
  value ? `${product.currency} ${value.toLocaleString("es-AR")}` : "Precio a confirmar";
const priceLabel = formatPrice(product.price);
const compareAt = product.compareAt || null;
const discount = compareAt && product.price ? Math.round(100 - (product.price / compareAt) * 100) : null;
const initialCtaLabel =
  product.colors?.length && product.sizes?.length
    ? "Elegí color y talle"
    : product.colors?.length
      ? "Elegí color"
      : product.sizes?.length
        ? "Elegí talle"
        : "Agregar al carrito";
const nameLower = product.name?.toLowerCase?.() ?? "";
const categoryLower = (product.category ?? "").toString().toLowerCase();
const typeLabel =
  nameLower.includes("bermuda") ? "Bermuda" :
  nameLower.includes("pantalon") ? "Pantalón" :
  nameLower.includes("camisa") ? "Camisa" :
  nameLower.includes("chomba") ? "Chomba" :
  nameLower.includes("remera") ? "Remera" :
  nameLower.includes("sandalia") ? "Sandalia" :
  categoryLower === "top" ? "Top" :
  categoryLower === "bottom" ? "Bottom" :
  categoryLower === "calzado" ? "Calzado" :
  (product.category ?? "").toString();
const summaryBullets = (() => {
  const bullets = [];
  const pushUnique = (value = "") => {
    const item = String(value).trim();
    if (!item) return;
    const exists = bullets.some((entry) => entry.toLowerCase() === item.toLowerCase());
    if (!exists) bullets.push(item);
  };
  const micro = product.microcopy?.trim?.();
  pushUnique(micro);
  const fit = product.fit?.trim?.();
  pushUnique(fit);
  if (product.materials?.length) pushUnique(product.materials.slice(0, 2).join(" · "));
  if (bullets.length < 3 && product.colors?.length) pushUnique(`Colores: ${product.colors.slice(0, 3).join(" · ")}`);
  return bullets.slice(0, 3);
})();

const swatchFor = (label = "") => {
  const key = label.trim().toLowerCase();
  const map = {
    negro: "#111214",
    blanco: "#f6f2ea",
    beige: "#d7c3a4",
    crudo: "#ece3d3",
    camel: "#c19a6b",
    mostaza: "#b9821e",
    oliva: "#6b6a3a",
    terracota: "#b3563f"
  };
  return map[key] || "#c9c3bb";
};
---

<Base title={`Fortunato | ${product.name}`} description={product.description}>
  <Header />

  <main class="pdp">
    {/* 1) Imagen full width */}
    <section class:list={{ "pdp-hero": true, "is-contained": useContainedHero }} aria-label={`Fotos de ${product.name}`}>
      <div class:list={{ "pdp-gallery": true, "is-single": hasSingleImage, "is-editorial": isEditorialHero }}>
        <div class="pdp-main-stage">
          <Image
            class="pdp-hero__img"
            src={initialMainImage}
            alt={product.name}
            priority
            width={1200}
            height={1500}
            decoding="async"
            data-pdp-main-image
          />
        </div>
        {product.badge ? <span class="pdp-badge">{product.badge}</span> : null}
        {galleryImages.length > 1 ? (
          <ul class="pdp-thumbs" aria-label="Más fotos">
            {galleryImages.map((src) => (
              <li>
                <button
                  type="button"
                  class:list={{ "pdp-thumb": true, "is-active": src === initialMainImage }}
                  data-pdp-thumb={src}
                  aria-label={`Ver foto de ${product.name}`}
                  aria-pressed={src === initialMainImage ? "true" : "false"}
                >
                  <Image src={src} alt="" loading="eager" width={160} height={200} decoding="async" />
                </button>
              </li>
            ))}
          </ul>
        ) : null}
      </div>
    </section>

    {/* 2) Resumen: SOLO título + detalles */}
    <section class="pdp-summary" aria-label="Resumen">
      <p class="pdp-kicker">{typeLabel}</p>
      <h1 class="pdp-title">{product.name}</h1>
      {summaryBullets.length ? (
        <ul class="pdp-highlights">
          {summaryBullets.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      ) : null}
    </section>

    {/* 3) Compra: precio + envio + talles + CTA */}
    <section class="pdp-buy" aria-label="Compra">
      <div class="pdp-buycard">
        <div class="pdp-price">
          <div class="pdp-price-row">
            <p class="pdp-price__current">{priceLabel}</p>
            {compareAt ? <p class="pdp-price__compare">{formatPrice(compareAt)}</p> : null}
            {discount ? <span class="pdp-discount">{discount}% OFF</span> : null}
          </div>
          <p class="pdp-installments muted">Pagás el subtotal por Mercado Pago y coordinamos el envío por WhatsApp.</p>
        </div>

        {product.colors?.length ? (
          <div class="pdp-colors" aria-label="Colores">
            <p class="pdp-field-label">Color</p>
            <ul class="pdp-color-grid" aria-label="Opciones de color">
              {product.colors.map((color) => (
                <li>
                  <button
                    type="button"
                    class="pdp-color"
                    data-color-option={color}
                    style={`--swatch:${swatchFor(color)};`}
                    aria-pressed="false"
                  >
                    <span class="pdp-swatch" aria-hidden="true"></span>
                    <span>{color}</span>
                  </button>
                </li>
              ))}
            </ul>
            <input type="hidden" name="color" value="" data-color-value />
            <p class="pdp-color-hint muted" data-color-hint>Seleccioná un color para continuar.</p>
          </div>
        ) : null}

        {product.sizes?.length ? (
          <div class="pdp-sizes" aria-label="Talles">
            <p class="pdp-field-label">Talle</p>
            <ul class="pdp-size-grid" aria-label="Opciones de talle">
              {product.sizes.map((size) => (
                <li>
                  <button type="button" class="pdp-size" data-size-option={size} aria-pressed="false">
                    {size}
                  </button>
                </li>
              ))}
            </ul>
            <input type="hidden" name="size" value="" data-size-value />
            <p class="pdp-size-hint muted" data-size-hint>Seleccioná tu talle para agregar al carrito.</p>
          </div>
        ) : null}

        <div class="pdp-ctas">
          <button
            class="btn pdp-cta"
            data-add-to-cart
            data-id={product.id}
            data-name={product.name}
            data-price={product.price ?? 0}
            data-currency={product.currency}
            data-image={initialMainImage}
            data-requires-color={product.colors?.length ? "1" : "0"}
            data-requires-size={product.sizes?.length ? "1" : "0"}
            disabled={product.colors?.length || product.sizes?.length ? true : undefined}
          >
            {initialCtaLabel}
          </button>
          <button
            class="btn btn-ghost pdp-cta"
            type="button"
            data-buy-now
            data-id={product.id}
            data-name={product.name}
            data-price={product.price ?? 0}
            data-currency={product.currency}
            data-image={initialMainImage}
            data-requires-color={product.colors?.length ? "1" : "0"}
            data-requires-size={product.sizes?.length ? "1" : "0"}
            disabled={product.colors?.length || product.sizes?.length ? true : undefined}
          >
            Comprar ahora
          </button>
        </div>
      </div>
    </section>

    {/* 4) Detalles extendidos */}
    <section class="pdp-details" aria-label="Detalles">
      <h2>Descripción</h2>
      <p class="muted pdp-description">{product.description}</p>

      {product.materials?.length ? (
        <>
          <h2>Materiales</h2>
          <div class="pill-list">
            {product.materials.map((item) => (
              <span class="pill">{item}</span>
            ))}
          </div>
        </>
      ) : null}

      {product.highlights?.length ? (
        <>
          <h2>Detalles</h2>
          <ul class="product-highlights">
            {product.highlights.map((item) => (
              <li>• {item}</li>
            ))}
          </ul>
        </>
      ) : null}
    </section>
  </main>

  <Footer />

  <script>
    const root = document.querySelector(".pdp");
    if (root) {
      const mainImage = root.querySelector("[data-pdp-main-image]");
      const thumbs = Array.from(root.querySelectorAll("[data-pdp-thumb]"));

      const setMainImage = (src) => {
        if (!mainImage || !src) return;
        mainImage.src = src;
        mainImage.removeAttribute("srcset");
        const cta = root.querySelector("[data-add-to-cart]");
        const buyNow = root.querySelector("[data-buy-now]");
        if (cta) cta.dataset.image = src;
        if (buyNow) buyNow.dataset.image = src;
        thumbs.forEach((btn) => {
          const isActive = btn.dataset.pdpThumb === src;
          btn.classList.toggle("is-active", isActive);
          btn.setAttribute("aria-pressed", isActive ? "true" : "false");
        });
      };

      thumbs.forEach((btn) => {
        btn.addEventListener("click", () => setMainImage(btn.dataset.pdpThumb || ""));
      });

      const colorInput = root.querySelector("[data-color-value]");
      const colorHint = root.querySelector("[data-color-hint]");
      const colorButtons = Array.from(root.querySelectorAll("[data-color-option]"));
      const sizeInput = root.querySelector("[data-size-value]");
      const hint = root.querySelector("[data-size-hint]");
      const sizeButtons = Array.from(root.querySelectorAll("[data-size-option]"));
      const cta = root.querySelector("[data-add-to-cart]");
      const buyNow = root.querySelector("[data-buy-now]");

      const requiresColor = cta?.dataset.requiresColor === "1";
      const requiresSize = cta?.dataset.requiresSize === "1";

      const updateCta = () => {
        if (!cta) return;
        const hasColor = Boolean(cta.dataset.color);
        const hasSize = Boolean(cta.dataset.size);

        let label = "Agregar al carrito";
        let disabled = false;

        if (requiresColor && requiresSize) {
          if (!hasColor && !hasSize) {
            label = "Elegí color y talle";
            disabled = true;
          } else if (!hasColor) {
            label = "Elegí color";
            disabled = true;
          } else if (!hasSize) {
            label = "Elegí talle";
            disabled = true;
          }
        } else if (requiresColor) {
          if (!hasColor) {
            label = "Elegí color";
            disabled = true;
          }
        } else if (requiresSize) {
          if (!hasSize) {
            label = "Elegí talle";
            disabled = true;
          }
        }

        cta.disabled = disabled;
        cta.textContent = label;

        if (buyNow) {
          buyNow.disabled = disabled;
          buyNow.textContent = "Comprar ahora";
        }
      };

      const setColor = (value) => {
        if (colorInput) colorInput.value = value;
        colorButtons.forEach((btn) => {
          const isSelected = btn.dataset.colorOption === value;
          btn.classList.toggle("is-selected", isSelected);
          btn.setAttribute("aria-pressed", isSelected ? "true" : "false");
        });
        if (colorHint) colorHint.textContent = value ? `Color seleccionado: ${value}` : "Seleccioná un color para continuar.";
        if (cta) cta.dataset.color = value || "";
        if (buyNow) buyNow.dataset.color = value || "";

        // Preparado para stock por variante: cambiar color resetea talle.
        if (requiresSize) {
          if (sizeInput) sizeInput.value = "";
          sizeButtons.forEach((btn) => btn.classList.remove("is-selected"));
          if (hint) hint.textContent = "Seleccioná tu talle para continuar.";
          if (cta) cta.dataset.size = "";
          if (buyNow) buyNow.dataset.size = "";
        }

        updateCta();
      };

      const setSize = (value) => {
        if (sizeInput) sizeInput.value = value;
        sizeButtons.forEach((btn) => {
          const isSelected = btn.dataset.sizeOption === value;
          btn.classList.toggle("is-selected", isSelected);
          btn.setAttribute("aria-pressed", isSelected ? "true" : "false");
        });
        if (hint) hint.textContent = value ? `Talle seleccionado: ${value}` : "Seleccioná tu talle para continuar.";
        if (cta) cta.dataset.size = value || "";
        if (buyNow) buyNow.dataset.size = value || "";
        updateCta();
      };

      colorButtons.forEach((btn) => {
        btn.addEventListener("click", () => setColor(btn.dataset.colorOption || ""));
      });

      sizeButtons.forEach((btn) => {
        btn.addEventListener("click", () => setSize(btn.dataset.sizeOption || ""));
      });

      updateCta();
    }
  </script>
</Base>
